@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="d-flex align-items-center justify-content-center px-3"
     style="min-height: calc(100vh - 56px);">
    <div class="app-card p-4 text-center" style="max-width: 520px; width: 100%;">
        <div class="mb-2">
            <h4 class="text-white mb-1">🚫 Acesso Negado</h4>
            <div class="app-muted">
                Você não tem permissão para acessar esta área do sistema.
            </div>
        </div>

        <div class="mt-4">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="btn btn-primary"
               style="min-width: 210px;">
                Voltar ao Dashboard
            </a>
        </div>
    </div>
</div>
