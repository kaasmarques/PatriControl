@model IEnumerable<PatriControl.Web.Models.TipoPatrimonio>

@{
    ViewData["Title"] = "Tipos de Patrimônio";

    string filtro = ViewBag.Filtro as string ?? "";

    int total = ViewBag.Total is int totalCount ? totalCount : Model.Count();
    int paginaAtual = ViewBag.Page is int pageNow ? pageNow : 1;
    int pageSize = ViewBag.PageSize is int ps ? ps : 10;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int exibindo = ViewBag.Exibindo is int ex ? ex : Model.Count();
}

<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h4 class="mb-1 text-white">Tipos de Patrimônio</h4>
        <div class="app-muted">Gerencie os tipos disponíveis para cadastro de patrimônio.</div>
    </div>

    <button type="button"
            class="app-icon-btn"
            aria-label="Adicionar tipo de patrimônio"
            title="Adicionar tipo de patrimônio"
            data-bs-toggle="modal"
            data-bs-target="#modalNovoTipo">
        <i class="bi bi-plus-square-fill" style="font-size:34px;"></i>
    </button>
</div>

<div class="app-card p-3">

    <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="text-white fw-semibold">Filtros</div>

        <div class="app-muted small text-end">
            Total: <b class="text-white">@total</b>
            <span class="mx-1">•</span>
            Página <b class="text-white">@paginaAtual</b>/<b class="text-white">@totalPages</b>
            <span class="mx-1">•</span>
            Exibindo <b class="text-white">@exibindo</b>
        </div>
    </div>

    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-3">
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@pageSize" />

        <div class="col-12 col-md-7">
            <label class="app-label mb-1">Buscar</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text"
                       name="filtro"
                       value="@filtro"
                       class="form-control"
                       placeholder="Filtrar tipos..." />
            </div>
        </div>

        <div class="col-12 col-md-auto">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" style="min-width:110px;">
                    Filtrar
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary"
                   style="min-width:110px;">
                    Limpar
                </a>
            </div>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-dark-soft table-hover align-middle mb-0">
            <thead>
                <tr class="app-table-head">
                    <th>TIPO</th>
                    <th style="width:160px;" class="text-end">AÇÕES</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="2" class="app-muted">Nenhum tipo cadastrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var tipo in Model)
                    {
                        <tr>
                            <td class="text-white">@tipo.Nome</td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        data-id="@tipo.Id"
                                        data-nome="@tipo.Nome"
                                        onclick="abrirModalEditarTipo(this)">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paginação (padrão do sistema) -->
    @if (ViewBag.Paginacao != null && totalPages > 1)
    {
        <div class="mt-3">
            @await Html.PartialAsync("_paginacao", (object)ViewBag.Paginacao)
        </div>
    }
</div>

<!-- =================================================
   MODAL (BOOTSTRAP): NOVO TIPO
   ================================================= -->
<div class="modal fade" id="modalNovoTipo" tabindex="-1" aria-labelledby="modalNovoTipoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-white" id="modalNovoTipoLabel">Novo Tipo de Patrimônio</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Create" method="post" id="formNovoTipo">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <label class="form-label app-label app-label-required">Nome do tipo</label>
                    <input class="form-control" name="nome" required />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL (BOOTSTRAP): EDITAR TIPO
   ================================================= -->
<div class="modal fade" id="modalEditarTipo" tabindex="-1" aria-labelledby="modalEditarTipoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-white" id="modalEditarTipoLabel">Editar Tipo de Patrimônio</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Edit" method="post" id="formEditarTipo">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="edit-tipo-id" />

                <div class="modal-body">
                    <label class="form-label app-label app-label-required">Nome do tipo</label>
                    <input class="form-control" name="nome" id="edit-tipo-nome" required />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModalEditarTipo(btn) {
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome') || '';

            document.getElementById('edit-tipo-id').value = id;
            document.getElementById('edit-tipo-nome').value = nome;

            const modalEl = document.getElementById('modalEditarTipo');
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        }

        // Sempre limpa o form ao abrir o modal de "Novo"
        document.addEventListener('DOMContentLoaded', function () {
            const modalNovoEl = document.getElementById('modalNovoTipo');
            if (modalNovoEl) {
                modalNovoEl.addEventListener('show.bs.modal', function () {
                    const form = document.getElementById('formNovoTipo');
                    if (form) form.reset();
                });
            }
        });
    </script>
}
