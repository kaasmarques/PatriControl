        function formatarDataHoraBr(iso) {
            if (!iso) return "";
            const d = new Date(iso);
            if (isNaN(d.getTime())) return "";
            return d.toLocaleString("pt-BR");
        }

        function carregarTramites(patrimonioId) {
            const container = document.getElementById('det-tramites');
            if (!container) return;

            container.innerHTML = '<div class="app-muted">Carregando histórico...</div>';

            fetch(`/Patrimonios/Tramites?id=${patrimonioId}`)
                .then(r => r.ok ? r.json() : [])
                .then(lista => {
                    if (!lista || !lista.length) {
                        container.innerHTML = '<div class="app-muted">Nenhum trâmite registrado.</div>';
                        return;
                    }

                    let html = "";
                    lista.forEach(t => {
                        const tipo = t.tipo || "";
                        const nome = t.nomeUsuario || "";
                        const data = formatarDataHoraBr(t.dataHora);

                        let codigo = "";
                        if (t.usuarioId && t.usuarioId > 0) {
                            codigo = "USR" + String(t.usuarioId).padStart(3, "0");
                        }

                        const usuarioLabel = codigo ? `${codigo} | ${nome}` : nome;

                        if (tipo === "PERSONALIZADO") {
                            const texto = t.valorNovo || t.valorAntigo || "";
                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} escreveu</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                    <div class="app-tramite-campo">
                                        ${escapeHtml(texto)}
                                    </div>
                                </div>
                            `;
                        } else if (tipo === "CRIACAO") {
                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} criou o patrimônio</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                </div>
                            `;
                        } else {
                            const campo  = t.campo || "";
                            const antigo = t.valorAntigo || "";
                            const novo   = t.valorNovo || "";

                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} alterou</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                    <div class="app-tramite-campo">
                                        ${escapeHtml(campo)}: <b>${escapeHtml(antigo)}</b> → <b>${escapeHtml(novo)}</b>
                                    </div>
                                </div>
                            `;
                        }
                    });

                    container.innerHTML = html;
                })
                .catch(() => {
                    container.innerHTML = '<div class="text-danger">Erro ao carregar trâmites.</div>';
                });
        }

