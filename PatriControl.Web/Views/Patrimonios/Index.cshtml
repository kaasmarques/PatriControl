   }
       const token = getAntiForgeryToken('form-edit-patrimonio');
 formData.append('__RequestVerificationToken', token);
            fetch('/Patrimonios/UploadFotos', { method: 'POST', body: formData })
       .then(r => r.ok ? r.json() : { ok: false, message: "Erro ao enviar." })
  .then(res => {
 input.value = '';
   if (!res.ok) { showToast(res.message || "Erro ao enviar fotos.", "danger"); return; }
