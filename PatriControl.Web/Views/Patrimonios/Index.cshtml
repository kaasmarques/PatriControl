        function trySyncExactFromInput(inputId, hiddenId, list, propName) {
            const input = document.getElementById(inputId);
            const hidden = document.getElementById(hiddenId);
            if (!input || !hidden) return;

            const txt = (input.value || "").trim();
            if (!txt) { hidden.value = ""; return; }

            const found = list.find(x => (x[propName] || "").trim().toLowerCase() === txt.toLowerCase());
            if (found) hidden.value = (found[propName] || "").trim();
        }

