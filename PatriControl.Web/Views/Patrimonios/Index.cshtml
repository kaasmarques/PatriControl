@model IEnumerable<PatriControl.Web.Models.Patrimonio>
@using System.Text.Json
@using PatriControl.Web.Models

@{
    ViewData["Title"] = "Patrimônios";

    var tiposDb = ViewBag.Tipos as List<TipoPatrimonio> ?? new List<TipoPatrimonio>();
    var fornecedoresDb = ViewBag.Fornecedores as List<Fornecedor> ?? new List<Fornecedor>();
    var unidadesDb = ViewBag.Unidades as List<Unidade> ?? new List<Unidade>();
    var localizacoesDb = ViewBag.Localizacoes as List<Localizacao> ?? new List<Localizacao>();

    // ===== Paginação (vem do controller) =====
    int total = ViewBag.Total ?? 0;
    int paginaAtual = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;
    int totalPages = ViewBag.TotalPages ?? 1;

    // ===== Filtros atuais =====
    string fNumero = ViewBag.FiltroNumero ?? "";
    string fDescricao = ViewBag.FiltroDescricao ?? "";
    string fUnidade = ViewBag.FiltroUnidade ?? "";
    string fStatus = ViewBag.FiltroStatus ?? "";
    string fCondicao = ViewBag.FiltroCondicao ?? "";

    // Lista de unidades (PER + Nome)
    var unidadesJs = JsonSerializer.Serialize(
        unidadesDb.Select(u => new
        {
            id = u.Id,
            per = u.Per,
            nome = u.Nome,
            display = (u.Per + " " + u.Nome).Trim()
        })
    );

    // Lista de localizações por unidade (FK UnidadeId)
    var localizacoesJs = JsonSerializer.Serialize(
        localizacoesDb.Select(l => new
        {
            id = l.Id,
            unidadeId = l.UnidadeId,
            nome = l.Nome
        })
    );

    var tiposJs = JsonSerializer.Serialize(
        tiposDb
            .Select(t => (t.Nome ?? "").Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x)
            .Select(x => new { nome = x })
    );

    var fornecedoresJs = JsonSerializer.Serialize(
        fornecedoresDb
            .Select(f => (f.Nome ?? "").Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x)
            .Select(x => new { nome = x })
    );

    // Listas para selects (Export)
    var tiposSelect = tiposDb
        .Select(t => (t.Nome ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var fornecedoresSelect = fornecedoresDb
        .Select(f => (f.Nome ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var unidadesSelect = unidadesDb
        .Select(u => (u.Per + " " + u.Nome).Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

<!-- Header -->
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h4 class="mb-1 text-white">Patrimônios</h4>
        <div class="app-muted">Listagem dos patrimônios cadastrados.</div>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <!-- Exportar Excel -->
        <button type="button"
                onclick="abrirExportarExcel()"
                class="app-icon-btn"
                aria-label="Exportar para Excel"
                title="Exportar para Excel">
            <i class="bi bi-file-earmark-excel-fill" style="font-size:34px;"></i>
        </button>

        <!-- Criar -->
        <button type="button"
                onclick="abrirCriarPatrimonio()"
                class="app-icon-btn"
                aria-label="Adicionar patrimônio"
                title="Adicionar patrimônio">
            <i class="bi bi-plus-square-fill" style="font-size:34px;"></i>
        </button>
    </div>
</div>

<!-- Filtros -->
<form method="get" class="app-card p-3 mb-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
        <div class="text-white fw-semibold">Filtros</div>

        <div class="app-muted small">
            Total: <b class="text-white">@total</b>
            • Página <b class="text-white">@paginaAtual</b>/<b class="text-white">@totalPages</b>
            • Exibindo <b class="text-white">@Model.Count()</b>
        </div>
    </div>

    <div class="row g-2 g-md-3">
        <div class="col-12 col-md-3">
            <label class="form-label app-label">Número</label>
            <input name="numero" value="@fNumero" class="form-control" placeholder="Ex: 9999" />
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label app-label">Descrição</label>
            <input name="descricao" value="@fDescricao" class="form-control" placeholder="Ex: Monitor / Notebook..." />
        </div>

        <!--  Unidade (combobox filtrável) -->
        <div class="col-12 col-md-5">
            <label class="form-label app-label">Unidade</label>

            <div class="app-combobox">
                <input type="hidden" id="filtro-unidade-value" name="unidade" value="@fUnidade" />

                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-building"></i></span>
                    <input type="text"
                           id="filtro-unidade-busca"
                           class="form-control"
                           placeholder="Digite para buscar unidade..."
                           value="@fUnidade"
                           autocomplete="off"
                           oninput="filtrarUnidadesFiltro()" />
                </div>

                <div id="filtro-unidade-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label app-label">Status</label>
            <select name="status" class="form-select" asp-items="ViewBag.StatusFiltroLista">
                <option value="">(Todos)</option>
            </select>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label app-label">Condição</label>
            <select name="condicao" class="form-select" asp-items="ViewBag.CondicaoFiltroLista">
                <option value="">(Todas)</option>
            </select>
        </div>

        <div class="col-12 col-md-4 d-flex align-items-end gap-2">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@pageSize" />

            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            <a class="btn btn-outline-secondary w-100" href="@Url.Action("Index", "Patrimonios")">Limpar</a>
        </div>
    </div>
</form>

<!-- Tabela -->
<div class="app-card p-3">
    <div class="table-responsive">
        <table class="table table-dark-soft table-hover align-middle mb-0">
            <thead>
                <tr class="app-table-head">
                    <th style="width:180px;">NÚMERO</th>
                    <th>DESCRIÇÃO</th>
                    <th style="width:260px;">UNIDADE</th>
                    <th style="width:190px;">STATUS</th>
                    <th style="width:160px;">CONDIÇÃO</th>
                    <th style="width:210px;" class="text-end">AÇÕES</th>
                </tr>
            </thead>
            <tbody id="patrimonios-tbody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="app-muted">Nenhum patrimônio encontrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        var payload = JsonSerializer.Serialize(new
                        {
                            id = p.Id,
                            numero = p.Numero,
                            descricao = p.Descricao,
                            unidade = p.Unidade,
                            localizacao = p.Localizacao,
                            tipo = p.Tipo,
                            fornecedor = p.Fornecedor,
                            numeroSerieNF = p.NumeroSerieNF,
                            numeroNF = p.NumeroNF,
                            valor = p.Valor,
                            dataCompra = p.DataCompra?.ToString("yyyy-MM-dd") ?? "",
                            status = p.Status,
                            condicao = p.Condicao
                        });

                        var bloqueado = string.Equals(p.Status?.Trim(), "Em manutenção", StringComparison.OrdinalIgnoreCase);

                        var statusKey = (p.Status ?? "").Trim().ToLowerInvariant();
                        var statusClass = statusKey switch
                        {
                            "ativo" => "app-badge-status app-badge-status-ativo",
                            "baixado" => "app-badge-status app-badge-status-baixado",
                            "emprestado" => "app-badge-status app-badge-status-emprestado",
                            "aguardando manutenção" => "app-badge-status app-badge-status-aguardando",
                            "em manutenção" => "app-badge-status app-badge-status-manutencao",
                            _ => "badge-soft"
                        };

                        <tr>
                            <td class="fw-semibold text-white">@(string.IsNullOrWhiteSpace(p.Numero) ? "-" : p.Numero)</td>
                            <td class="text-white">@p.Descricao</td>
                            <td class="app-muted">@p.Unidade</td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2 @statusClass">@p.Status</span>
                            </td>
                            <td class="app-muted">@p.Condicao</td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        data-patrimonio='@Html.Raw(payload)'
                                        onclick="abrirDetalhesPatrimonio(this)">
                                    Ver
                                </button>

                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary ms-1"
                                        data-patrimonio='@Html.Raw(payload)'
                                        @(bloqueado ? "disabled title=\"Patrimônio em manutenção: edição bloqueada\"" : "")
                                        onclick="@(bloqueado ? "return false;" : "abrirEditarPatrimonio(this)")">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paginação padronizada (partial) -->
    @{
        var rv = new Dictionary<string, object?>
        {
            ["numero"] = fNumero,
            ["descricao"] = fDescricao,
            ["unidade"] = fUnidade,
            ["status"] = fStatus,
            ["condicao"] = fCondicao
        };

        var pag = new PaginacaoViewModel
        {
            Page = paginaAtual,
            PageSize = pageSize,
            TotalPages = totalPages,
            Action = "Index",
            Controller = "Patrimonios",
            RouteValues = rv
        };
    }

    @await Html.PartialAsync("_Paginacao", pag)
</div>

<!-- =================================================
   MODAL: EXPORTAR EXCEL
   ================================================= -->
<div class="modal fade" id="modal-exportar-excel" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable modal-fullscreen-xxl-down">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Exportar patrimônios para Excel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="ExportExcel" asp-controller="Patrimonios" method="post" id="form-export-excel">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="app-muted mb-3">
                        Selecione os filtros abaixo ou deixe <b class="text-white">(Todos/as)</b> para exportar tudo.
                        <div class="small mt-1">Obs.: <b class="text-white">Localização</b> depende da <b class="text-white">Unidade</b>.</div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Unidade</label>
                            <select class="form-select" id="exp-unidade" name="unidade">
                                <option value="">(Todas)</option>
                                @foreach (var u in unidadesSelect)
                                {
                                    <option value="@u">@u</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Localização</label>
                            <select class="form-select" id="exp-localizacao" name="localizacao" disabled>
                                <option value="">(Todas)</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo</label>
                            <select class="form-select" id="exp-tipo" name="tipo">
                                <option value="">(Todos)</option>
                                @foreach (var t in tiposSelect)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Fornecedor</label>
                            <select class="form-select" id="exp-fornecedor" name="fornecedor">
                                <option value="">(Todos)</option>
                                @foreach (var f in fornecedoresSelect)
                                {
                                    <option value="@f">@f</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Status</label>
                            <select class="form-select" id="exp-status" name="status" asp-items="ViewBag.StatusFiltroLista">
                                <option value="">(Todos)</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Condição</label>
                            <select class="form-select" id="exp-condicao" name="condicao" asp-items="ViewBag.CondicaoFiltroLista">
                                <option value="">(Todas)</option>
                            </select>
                        </div>
                    </div>

                    <div class="app-muted small mt-3">
                        O Excel será gerado com as colunas:
                        <b class="text-white">
                            N° Patrimonio, Descrição, Unidade, Localização, Tipo, Fornecedor, N° Série NF, N° NF, Valor, Data de compra, Status, Condição.
                        </b>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-download me-1"></i> Exportar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL: DETALHES (Bootstrap)
   ================================================= -->
<div class="modal fade" id="modal-detalhes-patrimonio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Detalhes do Patrimônio</h5>
                <button type="button"
                        class="app-icon-btn ms-2"
                        aria-label="Duplicar patrimônio"
                        title="Duplicar patrimônio"
                        onclick="abrirDuplicarPatrimonio()">
                    <i class="bi bi-copy" style="font-size:22px;"></i>
                </button>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Número do Patrimônio</label>
                        <input class="form-control" id="det-numero" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Descrição</label>
                        <input class="form-control" id="det-descricao" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Unidade</label>
                        <input class="form-control" id="det-unidade" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Localização</label>
                        <input class="form-control" id="det-localizacao" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Tipo</label>
                        <input class="form-control" id="det-tipo" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Fornecedor</label>
                        <input class="form-control" id="det-fornecedor" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label app-label">Nº Série NF</label>
                        <input class="form-control" id="det-numero-serie-nf" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label app-label">Nº NF</label>
                        <input class="form-control" id="det-numero-nf" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label app-label">Valor</label>
                        <input class="form-control" id="det-valor" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label app-label">Data de Compra</label>
                        <input class="form-control" id="det-datacompra" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Status</label>
                        <input class="form-control" id="det-status" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Condição</label>
                        <input class="form-control" id="det-condicao" readonly tabindex="-1" />
                    </div>
                </div>

                <!-- Fotos do patrimônio -->
                <div class="mt-4">
                    <div class="text-white fw-semibold mb-1">Fotos do Patrimônio</div>
                    <div id="det-fotos-galeria" class="app-fotos-grid">
                        <div class="app-muted">Carregando fotos...</div>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <div class="text-white fw-semibold">Trâmites do Patrimônio</div>
                        <button type="button"
                                class="app-icon-btn"
                                aria-label="Adicionar trâmite"
                                title="Adicionar trâmite"
                                onclick="abrirTramitePersonalizado()">
                            <i class="bi bi-plus-square-fill" style="font-size:28px;"></i>
                        </button>
                    </div>
                    <div id="det-tramites" class="app-tramites-scroll">
                        <div class="app-muted">Carregando histórico...</div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL: EDITAR (Bootstrap)
   ================================================= -->
<div class="modal fade" id="modal-editar-patrimonio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Editar Patrimônio</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Edit" method="post" id="form-edit-patrimonio">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit-id" name="Id" />

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Número do patrimônio</label>
                            <input class="form-control" id="edit-numero" name="Numero" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Descrição</label>
                            <input class="form-control" id="edit-descricao" name="Descricao" required />
                        </div>

                        <!--  Unidade (combobox) -->
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Unidade</label>

                            <div class="app-combobox">
                                <input type="hidden" id="edit-unidade-id" value="" />
                                <input type="hidden" id="edit-unidade-value" name="Unidade" value="" />

                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-building"></i></span>
                                    <input type="text"
                                           id="edit-unidade-busca"
                                           class="form-control"
                                           placeholder="Digite para buscar unidade..."
                                           autocomplete="off"
                                           oninput="filtrarUnidadesEdit()" />
                                </div>

                                <div id="edit-unidade-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>
                        </div>

                        <!--  Localização (combobox - depende da unidade) -->
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Localização</label>

                            <div class="app-combobox">
                                <input type="hidden" id="edit-localizacao-value" name="Localizacao" value="" />

                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                    <input type="text"
                                           id="edit-localizacao-busca"
                                           class="form-control"
                                           placeholder="Selecione a unidade primeiro..."
                                           autocomplete="off"
                                           oninput="filtrarLocalizacoesEdit()" />
                                </div>

                                <div id="edit-localizacao-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>
                        </div>

                        <!--  Tipo (combobox) -->
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo</label>

                            <div class="app-combobox">
                                <input type="hidden" id="edit-tipo-value" name="Tipo" value="" />

                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                    <input type="text"
                                           id="edit-tipo-busca"
                                           class="form-control"
                                           placeholder="Digite para buscar tipo..."
                                           autocomplete="off"
                                           oninput="filtrarTiposEdit()" />
                                </div>

                                <div id="edit-tipo-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>
                        </div>

                        <!--  Fornecedor (combobox) -->
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Fornecedor</label>

                            <div class="app-combobox">
                                <input type="hidden" id="edit-fornecedor-value" name="Fornecedor" value="" />

                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-truck"></i></span>
                                    <input type="text"
                                           id="edit-fornecedor-busca"
                                           class="form-control"
                                           placeholder="Digite para buscar fornecedor..."
                                           autocomplete="off"
                                           oninput="filtrarFornecedoresEdit()" />
                                </div>

                                <div id="edit-fornecedor-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Nº Série NF</label>
                            <input class="form-control" id="edit-numero-serie-nf" name="NumeroSerieNF" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Nº NF</label>
                            <input class="form-control" id="edit-numero-nf" name="NumeroNF" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Valor</label>
                            <input class="form-control" id="edit-valor" name="ValorTexto" inputmode="decimal" autocomplete="off" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Data de Compra</label>
                            <input class="form-control" id="edit-datacompra" name="DataCompra" type="date" />
