@section Scripts {
    <script>
        const unidades = @Html.Raw(unidadesJs);
        const localizacoes = @Html.Raw(localizacoesJs);
        const tipos = @Html.Raw(tiposJs);
        const fornecedores = @Html.Raw(fornecedoresJs);

        // =========================================================
        // Helpers gerais
        // =========================================================
        function enc(s) { return encodeURIComponent(s || ""); }
        function dec(s) { return decodeURIComponent(s || ""); }

        function escapeHtml(str) {
            return String(str)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function showModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el, { backdrop: true });
            m.show();
        }

        function hideModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el);
            m.hide();
        }

        function hideBox(boxId) {
            const box = document.getElementById(boxId);
            if (box) box.style.display = 'none';
        }

        // Fecha dropdowns ao clicar fora
        document.addEventListener('click', function (e) {
            const combos = [
                { input: 'filtro-unidade-busca', box: 'filtro-unidade-opcoes' },

                { input: 'create-unidade-busca', box: 'create-unidade-opcoes' },
                { input: 'create-localizacao-busca', box: 'create-localizacao-opcoes' },
                { input: 'create-tipo-busca', box: 'create-tipo-opcoes' },
                { input: 'create-fornecedor-busca', box: 'create-fornecedor-opcoes' },

                { input: 'edit-unidade-busca', box: 'edit-unidade-opcoes' },
                { input: 'edit-localizacao-busca', box: 'edit-localizacao-opcoes' },
                { input: 'edit-tipo-busca', box: 'edit-tipo-opcoes' },
                { input: 'edit-fornecedor-busca', box: 'edit-fornecedor-opcoes' },
            ];

            combos.forEach(c => {
                const input = document.getElementById(c.input);
                const box = document.getElementById(c.box);
                if (!input || !box) return;

                if (!box.contains(e.target) && e.target !== input) {
                    box.style.display = 'none';
                }
            });
        });

        function getUnidadeByDisplay(display) {
            if (!display) return null;
            const d = (display || "").trim();
            return unidades.find(u => (u.display || "").trim() === d) || null;
        }

        function getUnidadeById(id) {
            const n = parseInt(id);
            if (!n) return null;
            return unidades.find(u => u.id === n) || null;
        }

        // =========================================================
        // EXPORT EXCEL (modal)
        // =========================================================
        function abrirExportarExcel() {
            const u = document.getElementById('exp-unidade');
            const l = document.getElementById('exp-localizacao');
            if (u) u.value = "";
            if (l) {
                l.innerHTML = `<option value="">(Todas)</option>`;
                l.disabled = true;
            }
            showModal('modal-exportar-excel');
        }

        function updateLocalizacoesExport() {
            const unidadeDisplay = (document.getElementById('exp-unidade')?.value || "").trim();
            const locSelect = document.getElementById('exp-localizacao');
            if (!locSelect) return;

            locSelect.innerHTML = `<option value="">(Todas)</option>`;
            locSelect.disabled = true;

            const uObj = getUnidadeByDisplay(unidadeDisplay);
            const unidadeId = uObj ? uObj.id : 0;

            if (!unidadeId) return;

            const locs = localizacoes
                .filter(x => x.unidadeId === unidadeId)
                .map(x => (x.nome || "").trim())
                .filter(x => !!x)
                .sort((a, b) => a.localeCompare(b));

            locs.forEach(n => {
                locSelect.insertAdjacentHTML('beforeend', `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`);
            });

            locSelect.disabled = false;
        }

        // =========================================================
        // Combobox: Unidade (Filtro)
        // =========================================================
        function filtrarUnidadesFiltro() {
            const input = document.getElementById('filtro-unidade-busca');
            const box = document.getElementById('filtro-unidade-opcoes');
            const hidden = document.getElementById('filtro-unidade-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = unidades
                .filter(u =>
                    (u.display || '').toLowerCase().includes(q) ||
                    (u.per || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q)
                )
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma unidade encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUnidadeFiltro(${u.id})">
                    <div><b>${escapeHtml(u.per || '')}</b> - ${escapeHtml(u.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarUnidadeFiltro(id) {
            const u = getUnidadeById(id);
            if (!u) return;

            document.getElementById('filtro-unidade-value').value = (u.display || '').trim();
            document.getElementById('filtro-unidade-busca').value = (u.display || '').trim();
            hideBox('filtro-unidade-opcoes');
        }

        // =========================================================
        // Combobox: Unidade (Create)
        // =========================================================
        function filtrarUnidadesCreate() {
            const input = document.getElementById('create-unidade-busca');
            const box = document.getElementById('create-unidade-opcoes');
            const hiddenValue = document.getElementById('create-unidade-value');
            const hiddenId = document.getElementById('create-unidade-id');
            const q = (input.value || '').toLowerCase().trim();

            hiddenValue.value = "";
            hiddenId.value = "";

            document.getElementById('create-localizacao-value').value = "";
            document.getElementById('create-localizacao-busca').value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = unidades
                .filter(u =>
                    (u.display || '').toLowerCase().includes(q) ||
                    (u.per || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q)
                )
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma unidade encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUnidadeCreate(${u.id})">
                    <div><b>${escapeHtml(u.per || '')}</b> - ${escapeHtml(u.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarUnidadeCreate(id) {
            const u = getUnidadeById(id);
            if (!u) return;

            document.getElementById('create-unidade-id').value = String(u.id);
            document.getElementById('create-unidade-value').value = (u.display || '').trim();
            document.getElementById('create-unidade-busca').value = (u.display || '').trim();

            document.getElementById('create-localizacao-value').value = "";
            document.getElementById('create-localizacao-busca').value = "";

            hideBox('create-unidade-opcoes');
        }

        // =========================================================
        // Combobox: Localização (Create)
        // =========================================================
        function filtrarLocalizacoesCreate() {
            const unidadeId = parseInt(document.getElementById('create-unidade-id').value || "0");
            const input = document.getElementById('create-localizacao-busca');
            const box = document.getElementById('create-localizacao-opcoes');
            const hidden = document.getElementById('create-localizacao-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!unidadeId) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Selecione uma unidade primeiro.</div>`;
                box.style.display = 'block';
                return;
            }

            if (!q) { box.style.display = 'none'; return; }

            const locs = localizacoes
                .filter(l => l.unidadeId === unidadeId && (l.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!locs.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma localização encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = locs.map(l => `
                <div class="app-combobox-item" onclick="selecionarLocalizacaoCreate('${enc(l.nome)}')">
                    <div>${escapeHtml(l.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarLocalizacaoCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-localizacao-value').value = nome;
            document.getElementById('create-localizacao-busca').value = nome;
            hideBox('create-localizacao-opcoes');
        }

        // =========================================================
        // Combobox: Tipo (Create)
        // =========================================================
        function filtrarTiposCreate() {
            const input = document.getElementById('create-tipo-busca');
            const box = document.getElementById('create-tipo-opcoes');
            const hidden = document.getElementById('create-tipo-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = tipos
                .filter(t => (t.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum tipo encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(t => `
                <div class="app-combobox-item" onclick="selecionarTipoCreate('${enc(t.nome)}')">
                    <div>${escapeHtml(t.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarTipoCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-tipo-value').value = nome;
            document.getElementById('create-tipo-busca').value = nome;
            hideBox('create-tipo-opcoes');
        }

        // =========================================================
        // Combobox: Fornecedor (Create)
        // =========================================================
        function filtrarFornecedoresCreate() {
            const input = document.getElementById('create-fornecedor-busca');
            const box = document.getElementById('create-fornecedor-opcoes');
            const hidden = document.getElementById('create-fornecedor-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = fornecedores
                .filter(f => (f.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum fornecedor encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(f => `
                <div class="app-combobox-item" onclick="selecionarFornecedorCreate('${enc(f.nome)}')">
                    <div>${escapeHtml(f.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarFornecedorCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-fornecedor-value').value = nome;
            document.getElementById('create-fornecedor-busca').value = nome;
            hideBox('create-fornecedor-opcoes');
        }

        // =========================================================
        // Edit: Unidade / Localização / Tipo / Fornecedor
        // =========================================================
        function filtrarUnidadesEdit() {
            const input = document.getElementById('edit-unidade-busca');
            const box = document.getElementById('edit-unidade-opcoes');
            const hiddenValue = document.getElementById('edit-unidade-value');
            const hiddenId = document.getElementById('edit-unidade-id');
            const q = (input.value || '').toLowerCase().trim();

