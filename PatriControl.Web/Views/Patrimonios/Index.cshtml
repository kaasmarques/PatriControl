        }

   // =========================================================
        // Helpers: Token + Toast
        // =========================================================
   function getAntiForgeryToken(formId) {
            const form = document.getElementById(formId);
            const token = form?.querySelector('input[name="__RequestVerificationToken"]');
     return token ? token.value : '';
        }

        function showToast(message, type = "success", delay) {
      const container = document.querySelector(".toast-container");
            if (!container) { alert(message); return; }
       const d = delay ?? (type === "danger" ? 4000 : 3000);
  const toast = document.createElement("div");
  toast.className = `toast align-items-center text-bg-${type} border-0 fade`;
            toast.setAttribute("role", "alert");
      toast.setAttribute("aria-live", "assertive");
            toast.setAttribute("aria-atomic", "true");
     toast.setAttribute("data-bs-delay", d.toString());
            toast.innerHTML = `
     <div class="d-flex">
       <div class="toast-body">${escapeHtml(message)}</div>
<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
          </div>`;
            container.appendChild(toast);
  const instance = bootstrap.Toast.getOrCreateInstance(toast, { delay: d });
      instance.show();
            toast.addEventListener("hidden.bs.toast", () => toast.remove());
    }

        // =========================================================
  // DOMContentLoaded
        // =========================================================
        document.addEventListener('DOMContentLoaded', function () {
// Export: change unidade
            const selUnidade = document.getElementById('exp-unidade');
       if (selUnidade) {
      selUnidade.addEventListener('change', function () { updateLocalizacoesExport(); });
   }

       // Validação Create
            const formCreate = document.getElementById('form-create-patrimonio');
     if (formCreate) {
          formCreate.addEventListener('submit', function (e) {
         trySyncExactFromInput('create-tipo-busca', 'create-tipo-value', tipos, 'nome');
     trySyncExactFromInput('create-fornecedor-busca', 'create-fornecedor-value', fornecedores, 'nome');
           const tipoHidden = (document.getElementById('create-tipo-value')?.value || "").trim();
         const tipoInput = (document.getElementById('create-tipo-busca')?.value || "").trim();
              if (!tipoHidden && tipoInput) { e.preventDefault(); alert("Selecione um Tipo válido na lista."); }
                });
   }

     // Validação Edit
   const formEdit = document.getElementById('form-edit-patrimonio');
        if (formEdit) {
        formEdit.addEventListener('submit', function (e) {
            trySyncExactFromInput('edit-tipo-busca', 'edit-tipo-value', tipos, 'nome');
          trySyncExactFromInput('edit-fornecedor-busca', 'edit-fornecedor-value', fornecedores, 'nome');
     const tipoHidden = (document.getElementById('edit-tipo-value')?.value || "").trim();
      const tipoInput = (document.getElementById('edit-tipo-busca')?.value || "").trim();
              if (tipoInput && !tipoHidden) { e.preventDefault(); alert("Selecione um Tipo válido na lista."); }
         });
         }

            // Upload de fotos no Edit (AJAX)
            const editFotosInput = document.getElementById('edit-fotos-input');
     if (editFotosInput) {
    editFotosInput.addEventListener('change', function () { uploadFotosEdit(); });
    }

            // Trâmite personalizado (AJAX)
            const formTramite = document.getElementById('form-tramite-personalizado');
            if (formTramite) {
        formTramite.addEventListener('submit', function (e) {
     e.preventDefault();
          const texto = (document.getElementById('tp-texto').value || "").trim();
         if (!texto) { showToast("Informe o trâmite.", "danger"); return; }
      const token = getAntiForgeryToken('form-tramite-personalizado');
        const body = new URLSearchParams();
        body.append("__RequestVerificationToken", token);
        body.append("patrimonioId", String(patrimonioAtualId));
        body.append("texto", texto);
 fetch('/Patrimonios/AdicionarTramitePersonalizado', {
  method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
  body: body.toString()
       })
    .then(r => r.ok ? r.json() : { ok: false, message: "Erro ao salvar." })
          .then(res => {
          if (!res.ok) { showToast(res.message || "Erro ao salvar.", "danger"); return; }
          hideModal('modal-tramite-personalizado');
      carregarTramites(patrimonioAtualId);
      showToast("Trâmite registrado com sucesso.", "success");
                 })
            .catch(() => showToast("Erro ao salvar.", "danger"));
     });
     }

 // Duplicar patrimônio (AJAX)
        const formDup = document.getElementById('form-duplicar-patrimonio');
            if (formDup) {
   formDup.addEventListener('submit', function (e) {
   e.preventDefault();
                    const quantidade = parseInt(document.getElementById('dup-quantidade').value || "0", 10);
  const erro = document.getElementById('dup-erro');
        const btnSalvar = document.getElementById('dup-btn-salvar');
    const showErr = (msg) => { if (!erro) return; erro.textContent = msg; erro.style.display = 'block'; };
   if (!quantidade || quantidade < 1 || quantidade > 100) { showErr("Informe uma quantidade entre 1 e 100."); return; }
              if (erro) { erro.style.display = 'none'; erro.textContent = ''; }
   btnSalvar.disabled = true;
        btnSalvar.textContent = "Duplicando...";
           const token = getAntiForgeryToken('form-duplicar-patrimonio');
        const body = new URLSearchParams();
         body.append("__RequestVerificationToken", token);
     body.append("patrimonioId", String(patrimonioAtualId));
           body.append("quantidade", String(quantidade));
       fetch('/Patrimonios/Duplicar', {
       method: 'POST',
             headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
         body: body.toString()
     })
 .then(r => r.ok ? r.json() : { ok: false, message: "Erro ao duplicar." })
        .then(res => {
btnSalvar.disabled = false;
      btnSalvar.textContent = "Duplicar";
        if (!res.ok) { showErr(res.message || "Erro ao duplicar."); return; }
    hideModal('modal-duplicar-patrimonio');
      showToast(res.quantidade === 1 ? "1 cópia criada com sucesso." : `${res.quantidade} cópias criadas com sucesso.`, "success");
   })
     .catch(() => {
          btnSalvar.disabled = false;
      btnSalvar.textContent = "Duplicar";
          showErr("Erro ao duplicar. Tente novamente.");
            });
                });
      }
        });
    </script>
}