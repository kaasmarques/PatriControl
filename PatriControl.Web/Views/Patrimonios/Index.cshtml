    const imgs = container ? container.querySelectorAll('.app-foto-thumb img') : [];
            lightboxFotos = [];
        let startIdx = 0;
            imgs.forEach((img, i) => {
          lightboxFotos.push({ caminho: img.src });
           const parentId = img.closest('.app-foto-thumb')?.id || '';
   if (parentId === `edit-foto-${fotoId}`) startIdx = i;
            });
     lightboxIndex = startIdx;
            renderLightbox();
   showModal('modal-foto-lightbox');
