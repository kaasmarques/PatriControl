   const body = new URLSearchParams();
            body.append('__RequestVerificationToken', token);
  body.append('fotoId', String(fotoId));
            fetch('/Patrimonios/ExcluirFoto', {
            method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
 body: body.toString()
            })
      .then(r => r.ok ? r.json() : { ok: false, message: "Erro." })
           .then(res => {
            if (!res.ok) { showToast(res.message || "Erro ao excluir.", "danger"); return; }
const el = document.getElementById(`edit-foto-${fotoId}`);
  if (el) el.remove();
      const container = document.getElementById('edit-fotos-existentes');
       if (container && !container.querySelector('.app-foto-thumb')) {
