@section Scripts {
    <script>
        const unidades = @Html.Raw(unidadesJs);
        const localizacoes = @Html.Raw(localizacoesJs);
        const tipos = @Html.Raw(tiposJs);
        const fornecedores = @Html.Raw(fornecedoresJs);

        // =========================================================
        // Helpers gerais
        // =========================================================
        function enc(s) { return encodeURIComponent(s || ""); }
        function dec(s) { return decodeURIComponent(s || ""); }

        function escapeHtml(str) {
            return String(str)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function showModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el, { backdrop: true });
            m.show();
        }

        function hideModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el);
            m.hide();
        }

        function hideBox(boxId) {
            const box = document.getElementById(boxId);
            if (box) box.style.display = 'none';
        }

        // Fecha dropdowns ao clicar fora
        document.addEventListener('click', function (e) {
            const combos = [
                { input: 'filtro-unidade-busca', box: 'filtro-unidade-opcoes' },

                { input: 'create-unidade-busca', box: 'create-unidade-opcoes' },
                { input: 'create-localizacao-busca', box: 'create-localizacao-opcoes' },
                { input: 'create-tipo-busca', box: 'create-tipo-opcoes' },
                { input: 'create-fornecedor-busca', box: 'create-fornecedor-opcoes' },

                { input: 'edit-unidade-busca', box: 'edit-unidade-opcoes' },
                { input: 'edit-localizacao-busca', box: 'edit-localizacao-opcoes' },
                { input: 'edit-tipo-busca', box: 'edit-tipo-opcoes' },
                { input: 'edit-fornecedor-busca', box: 'edit-fornecedor-opcoes' },
            ];

            combos.forEach(c => {
                const input = document.getElementById(c.input);
                const box = document.getElementById(c.box);
                if (!input || !box) return;

                if (!box.contains(e.target) && e.target !== input) {
                    box.style.display = 'none';
                }
            });
        });

        function getUnidadeByDisplay(display) {
            if (!display) return null;
            const d = (display || "").trim();
            return unidades.find(u => (u.display || "").trim() === d) || null;
        }

        function getUnidadeById(id) {
            const n = parseInt(id);
            if (!n) return null;
            return unidades.find(u => u.id === n) || null;
        }

        // =========================================================
        // EXPORT EXCEL (modal)
        // =========================================================
        function abrirExportarExcel() {
            // reset padrão
            const u = document.getElementById('exp-unidade');
            const l = document.getElementById('exp-localizacao');
            if (u) u.value = "";
            if (l) {
                l.innerHTML = `<option value="">(Todas)</option>`;
                l.disabled = true;
            }
            showModal('modal-exportar-excel');
        }

        function updateLocalizacoesExport() {
            const unidadeDisplay = (document.getElementById('exp-unidade')?.value || "").trim();
            const locSelect = document.getElementById('exp-localizacao');
            if (!locSelect) return;

            // limpa e bloqueia por padrão
            locSelect.innerHTML = `<option value="">(Todas)</option>`;
            locSelect.disabled = true;

            const uObj = getUnidadeByDisplay(unidadeDisplay);
            const unidadeId = uObj ? uObj.id : 0;

            if (!unidadeId) return;

            const locs = localizacoes
                .filter(x => x.unidadeId === unidadeId)
                .map(x => (x.nome || "").trim())
                .filter(x => !!x)
                .sort((a, b) => a.localeCompare(b));

            locs.forEach(n => {
                locSelect.insertAdjacentHTML('beforeend', `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`);
            });

            locSelect.disabled = false;
        }

        document.addEventListener('DOMContentLoaded', function () {
            const selUnidade = document.getElementById('exp-unidade');
            if (selUnidade) {
                selUnidade.addEventListener('change', function () {
                    // ao trocar unidade, recria localizações
                    updateLocalizacoesExport();
                });
            }
        });

        // =========================================================
        // Combobox: Unidade (Filtro)
        // =========================================================
        function filtrarUnidadesFiltro() {
            const input = document.getElementById('filtro-unidade-busca');
            const box = document.getElementById('filtro-unidade-opcoes');
            const hidden = document.getElementById('filtro-unidade-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = ""; // desseleciona até clicar numa opção

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = unidades
                .filter(u =>
                    (u.display || '').toLowerCase().includes(q) ||
                    (u.per || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q)
                )
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma unidade encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUnidadeFiltro(${u.id})">
                    <div><b>${escapeHtml(u.per || '')}</b> - ${escapeHtml(u.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarUnidadeFiltro(id) {
            const u = getUnidadeById(id);
            if (!u) return;

            document.getElementById('filtro-unidade-value').value = (u.display || '').trim();
            document.getElementById('filtro-unidade-busca').value = (u.display || '').trim();
            hideBox('filtro-unidade-opcoes');
        }

        // =========================================================
        // Combobox: Unidade (Create)
        // =========================================================
        function filtrarUnidadesCreate() {
            const input = document.getElementById('create-unidade-busca');
            const box = document.getElementById('create-unidade-opcoes');
            const hiddenValue = document.getElementById('create-unidade-value');
            const hiddenId = document.getElementById('create-unidade-id');
            const q = (input.value || '').toLowerCase().trim();

            hiddenValue.value = "";
            hiddenId.value = "";

            // ao digitar unidade, limpa localização
            document.getElementById('create-localizacao-value').value = "";
            document.getElementById('create-localizacao-busca').value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = unidades
                .filter(u =>
                    (u.display || '').toLowerCase().includes(q) ||
                    (u.per || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q)
                )
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma unidade encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUnidadeCreate(${u.id})">
                    <div><b>${escapeHtml(u.per || '')}</b> - ${escapeHtml(u.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarUnidadeCreate(id) {
            const u = getUnidadeById(id);
            if (!u) return;

            document.getElementById('create-unidade-id').value = String(u.id);
            document.getElementById('create-unidade-value').value = (u.display || '').trim();
            document.getElementById('create-unidade-busca').value = (u.display || '').trim();

            // limpa localização ao trocar unidade
            document.getElementById('create-localizacao-value').value = "";
            document.getElementById('create-localizacao-busca').value = "";

            hideBox('create-unidade-opcoes');
        }

        // =========================================================
        // Combobox: Localização (Create) - depende unidadeId
        // =========================================================
        function filtrarLocalizacoesCreate() {
            const unidadeId = parseInt(document.getElementById('create-unidade-id').value || "0");
            const input = document.getElementById('create-localizacao-busca');
            const box = document.getElementById('create-localizacao-opcoes');
            const hidden = document.getElementById('create-localizacao-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!unidadeId) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Selecione uma unidade primeiro.</div>`;
                box.style.display = 'block';
                return;
            }

            if (!q) { box.style.display = 'none'; return; }

            const locs = localizacoes
                .filter(l => l.unidadeId === unidadeId && (l.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!locs.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma localização encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = locs.map(l => `
                <div class="app-combobox-item" onclick="selecionarLocalizacaoCreate('${enc(l.nome)}')">
                    <div>${escapeHtml(l.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarLocalizacaoCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-localizacao-value').value = nome;
            document.getElementById('create-localizacao-busca').value = nome;
            hideBox('create-localizacao-opcoes');
        }

        // =========================================================
        // Combobox: Tipo (Create)
        // =========================================================
        function filtrarTiposCreate() {
            const input = document.getElementById('create-tipo-busca');
            const box = document.getElementById('create-tipo-opcoes');
            const hidden = document.getElementById('create-tipo-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = tipos
                .filter(t => (t.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum tipo encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(t => `
                <div class="app-combobox-item" onclick="selecionarTipoCreate('${enc(t.nome)}')">
                    <div>${escapeHtml(t.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarTipoCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-tipo-value').value = nome;
            document.getElementById('create-tipo-busca').value = nome;
            hideBox('create-tipo-opcoes');
        }

        // =========================================================
        // Combobox: Fornecedor (Create)
        // =========================================================
        function filtrarFornecedoresCreate() {
            const input = document.getElementById('create-fornecedor-busca');
            const box = document.getElementById('create-fornecedor-opcoes');
            const hidden = document.getElementById('create-fornecedor-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = fornecedores
                .filter(f => (f.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum fornecedor encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(f => `
                <div class="app-combobox-item" onclick="selecionarFornecedorCreate('${enc(f.nome)}')">
                    <div>${escapeHtml(f.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarFornecedorCreate(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('create-fornecedor-value').value = nome;
            document.getElementById('create-fornecedor-busca').value = nome;
            hideBox('create-fornecedor-opcoes');
        }

        // =========================================================
        // Edit: Unidade / Localização / Tipo / Fornecedor
        // =========================================================
        function filtrarUnidadesEdit() {
            const input = document.getElementById('edit-unidade-busca');
            const box = document.getElementById('edit-unidade-opcoes');
            const hiddenValue = document.getElementById('edit-unidade-value');
            const hiddenId = document.getElementById('edit-unidade-id');
            const q = (input.value || '').toLowerCase().trim();

            hiddenValue.value = "";
            hiddenId.value = "";

            // ao digitar unidade, limpa localização
            document.getElementById('edit-localizacao-value').value = "";
            document.getElementById('edit-localizacao-busca').value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = unidades
                .filter(u =>
                    (u.display || '').toLowerCase().includes(q) ||
                    (u.per || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q)
                )
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma unidade encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUnidadeEdit(${u.id})">
                    <div><b>${escapeHtml(u.per || '')}</b> - ${escapeHtml(u.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarUnidadeEdit(id) {
            const u = getUnidadeById(id);
            if (!u) return;

            document.getElementById('edit-unidade-id').value = String(u.id);
            document.getElementById('edit-unidade-value').value = (u.display || '').trim();
            document.getElementById('edit-unidade-busca').value = (u.display || '').trim();

            // limpa localização ao trocar unidade
            document.getElementById('edit-localizacao-value').value = "";
            document.getElementById('edit-localizacao-busca').value = "";

            hideBox('edit-unidade-opcoes');
        }

        function filtrarLocalizacoesEdit() {
            const unidadeId = parseInt(document.getElementById('edit-unidade-id').value || "0");
            const input = document.getElementById('edit-localizacao-busca');
            const box = document.getElementById('edit-localizacao-opcoes');
            const hidden = document.getElementById('edit-localizacao-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!unidadeId) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Selecione uma unidade primeiro.</div>`;
                box.style.display = 'block';
                return;
            }

            if (!q) { box.style.display = 'none'; return; }

            const locs = localizacoes
                .filter(l => l.unidadeId === unidadeId && (l.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!locs.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhuma localização encontrada.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = locs.map(l => `
                <div class="app-combobox-item" onclick="selecionarLocalizacaoEdit('${enc(l.nome)}')">
                    <div>${escapeHtml(l.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarLocalizacaoEdit(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('edit-localizacao-value').value = nome;
            document.getElementById('edit-localizacao-busca').value = nome;
            hideBox('edit-localizacao-opcoes');
        }

        function filtrarTiposEdit() {
            const input = document.getElementById('edit-tipo-busca');
            const box = document.getElementById('edit-tipo-opcoes');
            const hidden = document.getElementById('edit-tipo-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = tipos
                .filter(t => (t.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum tipo encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(t => `
                <div class="app-combobox-item" onclick="selecionarTipoEdit('${enc(t.nome)}')">
                    <div>${escapeHtml(t.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarTipoEdit(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('edit-tipo-value').value = nome;
            document.getElementById('edit-tipo-busca').value = nome;
            hideBox('edit-tipo-opcoes');
        }

        function filtrarFornecedoresEdit() {
            const input = document.getElementById('edit-fornecedor-busca');
            const box = document.getElementById('edit-fornecedor-opcoes');
            const hidden = document.getElementById('edit-fornecedor-value');
            const q = (input.value || '').toLowerCase().trim();

            hidden.value = "";

            if (!q) { box.style.display = 'none'; return; }

            const filtrados = fornecedores
                .filter(f => (f.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum fornecedor encontrado.</div>`;
                box.style.display = 'block';
                return;
            }

            box.innerHTML = filtrados.map(f => `
                <div class="app-combobox-item" onclick="selecionarFornecedorEdit('${enc(f.nome)}')">
                    <div>${escapeHtml(f.nome || '')}</div>
                </div>
            `).join('');

            box.style.display = 'block';
        }

        function selecionarFornecedorEdit(nomeEnc) {
            const nome = dec(nomeEnc);
            document.getElementById('edit-fornecedor-value').value = nome;
            document.getElementById('edit-fornecedor-busca').value = nome;
            hideBox('edit-fornecedor-opcoes');
        }

        // =========================================================
        // Validação: Tipo (Create/Edit) precisa ser válido
        // =========================================================
        function trySyncExactFromInput(inputId, hiddenId, list, propName) {
            const input = document.getElementById(inputId);
            const hidden = document.getElementById(hiddenId);
            if (!input || !hidden) return;

            const txt = (input.value || "").trim();
            if (!txt) { hidden.value = ""; return; }

            const found = list.find(x => (x[propName] || "").trim().toLowerCase() === txt.toLowerCase());
            if (found) hidden.value = (found[propName] || "").trim();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const formCreate = document.getElementById('form-create-patrimonio');
            if (formCreate) {
                formCreate.addEventListener('submit', function (e) {
                    trySyncExactFromInput('create-tipo-busca', 'create-tipo-value', tipos, 'nome');
                    trySyncExactFromInput('create-fornecedor-busca', 'create-fornecedor-value', fornecedores, 'nome');

                    const tipoHidden = (document.getElementById('create-tipo-value')?.value || "").trim();
                    const tipoInput = (document.getElementById('create-tipo-busca')?.value || "").trim();

                    if (!tipoHidden && tipoInput) {
                        e.preventDefault();
                        alert("Selecione um Tipo válido na lista.");
                    }
                });
            }

            const formEdit = document.getElementById('form-edit-patrimonio');
            if (formEdit) {
                formEdit.addEventListener('submit', function (e) {
                    trySyncExactFromInput('edit-tipo-busca', 'edit-tipo-value', tipos, 'nome');
                    trySyncExactFromInput('edit-fornecedor-busca', 'edit-fornecedor-value', fornecedores, 'nome');

                    const tipoHidden = (document.getElementById('edit-tipo-value')?.value || "").trim();
                    const tipoInput = (document.getElementById('edit-tipo-busca')?.value || "").trim();

                    if (tipoInput && !tipoHidden) {
                        e.preventDefault();
                        alert("Selecione um Tipo válido na lista.");
                    }
                });
            }
        });

        // =========================================================
        // Tramites / Detalhes (mantido)
        // =========================================================
        function formatarDataHoraBr(iso) {
            if (!iso) return "";
            const d = new Date(iso);
            if (isNaN(d.getTime())) return "";
            return d.toLocaleString("pt-BR");
        }

        function carregarTramites(patrimonioId) {
            const container = document.getElementById('det-tramites');
            if (!container) return;

            container.innerHTML = '<div class="app-muted">Carregando histórico...</div>';

            fetch(`/Patrimonios/Tramites?id=${patrimonioId}`)
                .then(r => r.ok ? r.json() : [])
                .then(lista => {
                    if (!lista || !lista.length) {
                        container.innerHTML = '<div class="app-muted">Nenhum trâmite registrado.</div>';
                        return;
                    }

                    let html = "";
                    lista.forEach(t => {
                        const tipo = t.tipo || "";
                        const nome = t.nomeUsuario || "";
                        const data = formatarDataHoraBr(t.dataHora);

                        let codigo = "";
                        if (t.usuarioId && t.usuarioId > 0) {
                            codigo = "USR" + String(t.usuarioId).padStart(3, "0");
                        }

                        const usuarioLabel = codigo ? `${codigo} | ${nome}` : nome;

                        if (tipo === "PERSONALIZADO") {
                            const texto = t.valorNovo || t.valorAntigo || "";
                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} escreveu</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                    <div class="app-tramite-campo">
                                        ${escapeHtml(texto)}
                                    </div>
                                </div>
                            `;
                        } else if (tipo === "CRIACAO") {
                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} criou o patrimônio</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                </div>
                            `;
                        } else {
                            const campo  = t.campo || "";
                            const antigo = t.valorAntigo || "";
                            const novo   = t.valorNovo || "";

                            html += `
                                <div class="app-tramite-item">
                                    <div class="app-tramite-header">
                                        <span>${usuarioLabel} alterou</span>
                                        <span class="app-muted">${data}</span>
                                    </div>
                                    <div class="app-tramite-campo">
                                        ${escapeHtml(campo)}: <b>${escapeHtml(antigo)}</b> → <b>${escapeHtml(novo)}</b>
                                    </div>
                                </div>
                            `;
                        }
                    });

                    container.innerHTML = html;
                })
                .catch(() => {
                    container.innerHTML = '<div class="text-danger">Erro ao carregar trâmites.</div>';
                });
        }

        function abrirDetalhesPatrimonio(botao) {
            const json = botao.getAttribute('data-patrimonio') || '{}';
            let p = {};
            try { p = JSON.parse(json); } catch { }

            //  define o patrimônio atual para o trâmite personalizado
            patrimonioAtualId = p.id || 0;

            document.getElementById('det-numero').value          = p.numero || '';
            document.getElementById('det-descricao').value       = p.descricao || '';
            document.getElementById('det-unidade').value         = p.unidade || '';
            document.getElementById('det-localizacao').value     = p.localizacao || '';
            document.getElementById('det-tipo').value            = p.tipo || '';
            document.getElementById('det-fornecedor').value      = p.fornecedor || '';
            document.getElementById('det-numero-serie-nf').value = p.numeroSerieNF || '';
            document.getElementById('det-numero-nf').value       = p.numeroNF || '';

            if (p.valor != null && p.valor !== "") {
                const numeroValor = Number(p.valor);
                if (!isNaN(numeroValor)) {
                    document.getElementById('det-valor').value =
                        numeroValor.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
                } else {
                    document.getElementById('det-valor').value = p.valor;
                }
            } else {
                document.getElementById('det-valor').value = '';
            }

            document.getElementById('det-datacompra').value = p.dataCompra || '';
            document.getElementById('det-status').value     = p.status || '';
            document.getElementById('det-condicao').value   = p.condicao || '';

            if (p.id) carregarTramites(p.id);
            else {
                const container = document.getElementById('det-tramites');
                if (container) container.innerHTML = '<div class="app-muted">Nenhum trâmite encontrado.</div>';
            }

            showModal('modal-detalhes-patrimonio');
        }

        function abrirEditarPatrimonio(botao) {
            const json = botao.getAttribute('data-patrimonio') || '{}';
            let p = {};
            try { p = JSON.parse(json); } catch { }

            document.getElementById('edit-id').value = p.id || 0;
            document.getElementById('edit-numero').value = p.numero || '';
            document.getElementById('edit-descricao').value = p.descricao || '';
            document.getElementById('edit-numero-serie-nf').value = p.numeroSerieNF || '';
            document.getElementById('edit-numero-nf').value = p.numeroNF || '';

            if (p.valor != null && p.valor !== "") {
                const numeroValor = Number(p.valor);
                if (!isNaN(numeroValor)) {
                    document.getElementById('edit-valor').value =
                        numeroValor.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                } else {
                    document.getElementById('edit-valor').value = p.valor;
                }
            } else {
                document.getElementById('edit-valor').value = '';
            }

            document.getElementById('edit-datacompra').value = p.dataCompra || '';
            document.getElementById('edit-status').value = p.status || 'Ativo';
            document.getElementById('edit-condicao').value = p.condicao || 'Novo';

            // Unidade / Localização
            const unidadeDisplay = (p.unidade || '').trim();
            const unidadeObj = getUnidadeByDisplay(unidadeDisplay);
            const unidadeId = unidadeObj ? unidadeObj.id : 0;

            document.getElementById('edit-unidade-busca').value = unidadeDisplay;
            document.getElementById('edit-unidade-value').value = unidadeDisplay;
            document.getElementById('edit-unidade-id').value = unidadeId ? String(unidadeId) : "";

            const loc = (p.localizacao || '').trim();
            document.getElementById('edit-localizacao-busca').value = loc;
            document.getElementById('edit-localizacao-value').value = loc;

            // Tipo / Fornecedor
            const tipo = (p.tipo || '').trim();
            document.getElementById('edit-tipo-busca').value = tipo;
            document.getElementById('edit-tipo-value').value = tipo;

            const forn = (p.fornecedor || '').trim();
            document.getElementById('edit-fornecedor-busca').value = forn;
            document.getElementById('edit-fornecedor-value').value = forn;

            showModal('modal-editar-patrimonio');
        }

        function abrirCriarPatrimonio() {
            const form = document.querySelector('#modal-criar-patrimonio form');
            if (form) form.reset();

            // limpa comboboxes (create)
            document.getElementById('create-unidade-id').value = "";
            document.getElementById('create-unidade-value').value = "";
            document.getElementById('create-unidade-busca').value = "";

            document.getElementById('create-localizacao-value').value = "";
            document.getElementById('create-localizacao-busca').value = "";

            document.getElementById('create-tipo-value').value = "";
            document.getElementById('create-tipo-busca').value = "";

            document.getElementById('create-fornecedor-value').value = "";
            document.getElementById('create-fornecedor-busca').value = "";

            showModal('modal-criar-patrimonio');
        }

        // =========================================================
        // Trâmites personalizados
        // =========================================================
        let patrimonioAtualId = 0;

        function abrirTramitePersonalizado() {
            if (!patrimonioAtualId) {
                showToast("Patrimônio inválido.", "danger");
                return;
            }

            document.getElementById('tp-patrimonio-id').value = patrimonioAtualId;
            document.getElementById('tp-texto').value = "";
            showModal('modal-tramite-personalizado');

            setTimeout(() => document.getElementById('tp-texto')?.focus(), 150);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const formTramite = document.getElementById('form-tramite-personalizado');
            if (formTramite) {
                formTramite.addEventListener('submit', function (e) {
                    e.preventDefault();

                    const texto = (document.getElementById('tp-texto').value || "").trim();
                    if (!texto) {
                        showToast("Informe o trâmite.", "danger");
                        return;
                    }

                    const token = getAntiForgeryToken('form-tramite-personalizado');
                    const body = new URLSearchParams();
                    body.append("__RequestVerificationToken", token);
                    body.append("patrimonioId", String(patrimonioAtualId));
                    body.append("texto", texto);

                    fetch('/Patrimonios/AdicionarTramitePersonalizado', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: body.toString()
                    })
                        .then(r => r.ok ? r.json() : { ok: false, message: "Erro ao salvar." })
                        .then(res => {
                            if (!res.ok) {
                                showToast(res.message || "Erro ao salvar.", "danger");
                                return;
                            }

                            hideModal('modal-tramite-personalizado');
                            carregarTramites(patrimonioAtualId);
                            showToast("Trâmite registrado com sucesso.", "success");
                        })
                        .catch(() => showToast("Erro ao salvar.", "danger"));
                });
            }
        });

        function getAntiForgeryToken(formId) {
            const form = document.getElementById(formId);
            const token = form?.querySelector('input[name="__RequestVerificationToken"]');
            return token ? token.value : '';
        }

        function showToast(message, type = "success", delay) {
            const container = document.querySelector(".toast-container");
            if (!container) {
                alert(message);
                return;
            }

            const d = delay ?? (type === "danger" ? 4000 : 3000);

            const toast = document.createElement("div");
            toast.className = `toast align-items-center text-bg-${type} border-0 fade`;
            toast.setAttribute("role", "alert");
            toast.setAttribute("aria-live", "assertive");
            toast.setAttribute("aria-atomic", "true");
            toast.setAttribute("data-bs-delay", d.toString());

            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${escapeHtml(message)}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            `;

            container.appendChild(toast);

            const instance = bootstrap.Toast.getOrCreateInstance(toast, { delay: d });
            instance.show();

            toast.addEventListener("hidden.bs.toast", () => toast.remove());
        }
    </script>
}
