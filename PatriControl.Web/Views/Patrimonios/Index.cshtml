        function renderLightbox() {
      const img = document.getElementById('lightbox-img');
         const counter = document.getElementById('lightbox-counter');
    if (!lightboxFotos.length) return;
            if (lightboxIndex < 0) lightboxIndex = lightboxFotos.length - 1;
   if (lightboxIndex >= lightboxFotos.length) lightboxIndex = 0;
     img.src = lightboxFotos[lightboxIndex].caminho;
    counter.textContent = `${lightboxIndex + 1} / ${lightboxFotos.length}`;
  const navs = document.querySelectorAll('.lightbox-nav');
            navs.forEach(n => n.style.display = lightboxFotos.length > 1 ? '' : 'none');
        }

        function lightboxPrev() { lightboxIndex--; renderLightbox(); }
        function lightboxNext() { lightboxIndex++; renderLightbox(); }

