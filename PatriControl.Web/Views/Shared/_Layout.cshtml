@using System.Security.Claims
<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PatriControl</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Tema novo -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modal-fix.css" asp-append-version="true" />
</head>

<body class="app-body">

    <!-- 🔔 TOASTS (Bootstrap) -->
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3" style="z-index: 1080;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast align-items-center text-bg-success border-0 fade"
                 role="alert" aria-live="assertive" aria-atomic="true"
                 data-bs-delay="3000">
                <div class="d-flex">
                    <div class="toast-body">@TempData["SuccessMessage"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast align-items-center text-bg-danger border-0 fade"
                 role="alert" aria-live="assertive" aria-atomic="true"
                 data-bs-delay="4000">
                <div class="d-flex">
                    <div class="toast-body">@TempData["ErrorMessage"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            </div>
        }
    </div>

    @if (User?.Identity?.IsAuthenticated == true)
    {
        var nome = User.Identity?.Name ?? "Usuário";
        var codigo = User.Claims.FirstOrDefault(c => c.Type == "Codigo")?.Value ?? "";
        var admin = User.Claims.FirstOrDefault(c => c.Type == "Administrador")?.Value == "True";

        <!-- TOPBAR -->
        <nav class="navbar navbar-expand-lg app-topbar sticky-top border-bottom">
            <div class="container-fluid px-3">

                <!-- BOTÃO MENU (mobile) -->
                <button class="btn btn-outline-secondary d-lg-none me-2"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#appSidebarMobile"
                        aria-controls="appSidebarMobile"
                        aria-label="Abrir menu">
                    ☰
                </button>

                <a class="navbar-brand d-flex align-items-center gap-2 m-0"
                   asp-controller="Dashboard" asp-action="Index">
                    <div class="app-logo mx-auto me-2">
                        <img src="~/images/logo-barcode.svg" class="app-logo-img" alt="PatriControl" />
                    </div>
                    <div class="lh-sm">
                        <div class="fw-semibold">PatriControl</div>
                        <div class="text-secondary small">Gestão de Patrimônio</div>
                    </div>
                </a>

                <div class="d-flex align-items-center gap-2 ms-auto">
                    <div class="d-none d-md-flex align-items-center gap-2 px-3 py-2 rounded-pill app-surface border">
                        <span class="fw-semibold">@nome</span>

                        @if (!string.IsNullOrWhiteSpace(codigo))
                        {
                            <span class="text-secondary">• @codigo</span>
                        }

                        @if (admin)
                        {
                            <span class="badge app-badge">Admin</span>
                        }
                    </div>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            Sair
                        </button>
                    </form>
                </div>

            </div>
        </nav>

        <!-- ✅ OFFCANVAS SIDEBAR (MOBILE) -->
        <div class="offcanvas offcanvas-start app-sidebar"
             tabindex="-1"
             id="appSidebarMobile"
             aria-labelledby="appSidebarMobileLabel">
            <div class="offcanvas-header border-bottom" style="border-color: var(--app-border) !important;">
                <h5 class="offcanvas-title text-white" id="appSidebarMobileLabel">Menu</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
            </div>
            <div class="offcanvas-body p-3">
                @await Html.PartialAsync("_Sidebar")
            </div>
        </div>

        <!-- Layout principal -->
        <div class="container-fluid px-0">
            <div class="row g-0">
                <!-- Sidebar (DESKTOP) -->
                <aside class="col-12 col-lg-2 app-sidebar border-end d-none d-lg-block"
                       style="min-height: calc(100vh - 57px);">
                    <div class="p-3">
                        @await Html.PartialAsync("_Sidebar")
                    </div>
                </aside>

                <!-- Conteúdo -->
                <main class="col-12 col-lg-10 py-4 px-3 px-lg-4">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="p-0">
            @RenderBody()
        </main>
    }

    <!-- Bootstrap JS (bundle) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery + validações -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.9/dist/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".toast").forEach(el => {
                const delay = el.dataset.bsDelay ? parseInt(el.dataset.bsDelay) : 3000;
                bootstrap.Toast.getOrCreateInstance(el, { delay }).show();
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
