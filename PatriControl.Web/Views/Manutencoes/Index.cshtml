        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Finalizar Manutenção</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Finalizar" method="post" id="form-finalizar">
                @Html.AntiForgeryToken()
                <input type="hidden" id="finalizar-id" name="id" />

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Código</label>
                            <input class="form-control" id="f-codigo" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Status</label>
                            <input class="form-control" value="Em andamento" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Patrimônio</label>
                            <input class="form-control" id="f-patrimonio" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo de Patrimônio</label>
                            <input class="form-control" id="f-tipopatrimonio" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo de Manutenção</label>
                            <input class="form-control" id="f-tipomanut" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Manutentor</label>
                            <input class="form-control" id="f-manutentor" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Aberta em</label>
                            <input class="form-control" id="f-abertaem" readonly tabindex="-1" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Aberta por</label>
                            <input class="form-control" id="f-abertapor" readonly tabindex="-1" />
