            <div class="modal-body">
                <div class="app-muted">
                    Tem certeza que deseja cancelar a manutenção <b id="c-codigo"></b>?
                    <br />Isso vai liberar o patrimônio novamente.
                </div>

                <form asp-action="Cancelar" method="post" class="mt-3 d-flex justify-content-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cancelar-id" name="id" />
                    <button type="submit" class="btn btn-danger">Sim, cancelar</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Voltar</button>
