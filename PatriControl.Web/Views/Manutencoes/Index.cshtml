@section Scripts {
    <script>
        let manutencaoAtual = null;

        const patrimonios = @Html.Raw(patrimoniosJs);
        const manutentores = @Html.Raw(manutentoresJs);
        const isAdmin = @((admin ? "true" : "false"));

        const patrimoniosFiltro = @Html.Raw(patrimoniosFiltroJs);
        const usuariosFiltro = @Html.Raw(usuariosFiltroJs);

        function showModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el, { backdrop: true });
            m.show();
        }
        function hideModal(id) {
            const el = document.getElementById(id);
            const m = bootstrap.Modal.getOrCreateInstance(el);
            m.hide();
        }

        function getAntiForgeryToken() {
            const el = document.querySelector('#anti-form input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        function esconderListasCombobox() {
            const p = document.getElementById('patrimonio-opcoes');
            const m = document.getElementById('manutentor-opcoes');
            if (p) p.style.display = 'none';
            if (m) m.style.display = 'none';

            const fp = document.getElementById('filtro-patrimonio-opcoes');
            const fu = document.getElementById('filtro-usuario-opcoes');
            if (fp) fp.style.display = 'none';
            if (fu) fu.style.display = 'none';
        }

        document.addEventListener('click', function (e) {
            const pc1 = document.getElementById('patrimonio-opcoes');
            const pc2 = document.getElementById('manutentor-opcoes');
            const in1 = document.getElementById('patrimonio-busca');
            const in2 = document.getElementById('manutentor-busca');

            if (pc1 && in1 && !pc1.contains(e.target) && e.target !== in1) pc1.style.display = 'none';
            if (pc2 && in2 && !pc2.contains(e.target) && e.target !== in2) pc2.style.display = 'none';

            const fp = document.getElementById('filtro-patrimonio-opcoes');
            const fu = document.getElementById('filtro-usuario-opcoes');
            const ip = document.getElementById('filtro-patrimonio-texto');
            const iu = document.getElementById('filtro-usuario-texto');

            if (fp && ip && !fp.contains(e.target) && e.target !== ip) fp.style.display = 'none';
            if (fu && iu && !fu.contains(e.target) && e.target !== iu) fu.style.display = 'none';
        });

        document.addEventListener('hidden.bs.modal', function (e) {
            esconderListasCombobox();
        });

        function filtrarPatrimoniosFiltro() {
            const input = document.getElementById('filtro-patrimonio-texto');
            const lista = document.getElementById('filtro-patrimonio-opcoes');
            const q = (input?.value || '').toLowerCase().trim();

            const hid = document.getElementById('filtro-patrimonio-id');
            if (hid) hid.value = '0';

            if (!lista) return;
            if (!q) { lista.style.display = 'none'; return; }

            const filtrados = patrimoniosFiltro
                .filter(p => (p.numero || '').toLowerCase().includes(q) || (p.descricao || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                lista.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum patrimônio encontrado.</div>`;
                lista.style.display = 'block';
                return;
            }

            lista.innerHTML = filtrados.map(p => `
                <div class="app-combobox-item" onclick="selecionarPatrimonioFiltro(${p.id})">
                    <div><b>${escapeHtml(p.numero || '')}</b> - ${escapeHtml(p.descricao || '')}</div>
                </div>
            `).join('');

            lista.style.display = 'block';
        }

        function selecionarPatrimonioFiltro(id) {
            const p = patrimoniosFiltro.find(x => x.id === id);
            if (!p) return;

            const hid = document.getElementById('filtro-patrimonio-id');
            const input = document.getElementById('filtro-patrimonio-texto');
            const lista = document.getElementById('filtro-patrimonio-opcoes');

            if (hid) hid.value = String(p.id);
            if (input) input.value = `${p.numero || ''} - ${p.descricao || ''}`.trim();
            if (lista) lista.style.display = 'none';
        }

        function filtrarUsuariosFiltro() {
            const input = document.getElementById('filtro-usuario-texto');
            const lista = document.getElementById('filtro-usuario-opcoes');
            const q = (input?.value || '').toLowerCase().trim();

            const hid = document.getElementById('filtro-usuario-id');
            if (hid) hid.value = '0';

            if (!lista) return;
            if (!q) { lista.style.display = 'none'; return; }

            const filtrados = usuariosFiltro
                .filter(u =>
                    (u.codigo || '').toLowerCase().includes(q) ||
                    (u.nome || '').toLowerCase().includes(q) ||
                    (u.sobrenome || '').toLowerCase().includes(q) ||
                    (u.email || '').toLowerCase().includes(q) ||
                    (((u.nome || '') + ' ' + (u.sobrenome || '')).toLowerCase().includes(q))
                )
                .slice(0, 25);

            if (!filtrados.length) {
                lista.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum usuário encontrado.</div>`;
                lista.style.display = 'block';
                return;
            }

            lista.innerHTML = filtrados.map(u => `
                <div class="app-combobox-item" onclick="selecionarUsuarioFiltro(${u.id})">
                    <div><b>${escapeHtml(u.codigo || '')}</b> - ${escapeHtml(((u.nome || '') + ' ' + (u.sobrenome || '')).trim())}</div>
                    <small>${escapeHtml(u.email || '')}</small>
                </div>
            `).join('');

            lista.style.display = 'block';
        }

        function selecionarUsuarioFiltro(id) {
            const u = usuariosFiltro.find(x => x.id === id);
            if (!u) return;

            const hid = document.getElementById('filtro-usuario-id');
            const input = document.getElementById('filtro-usuario-texto');
            const lista = document.getElementById('filtro-usuario-opcoes');

            if (hid) hid.value = String(u.id);
            if (input) input.value = `${u.codigo || ''} - ${((u.nome || '') + ' ' + (u.sobrenome || '')).trim()}`.trim();
            if (lista) lista.style.display = 'none';
        }

        function abrirCriarManutencao() {
            const form = document.getElementById('form-criar-manutencao');
            if (form) form.reset();

            document.getElementById('create-abertaem').value = new Date().toLocaleString("pt-BR");

            document.getElementById('patrimonioId').value = '';
            document.getElementById('tipo-patrimonio').value = '';
            document.getElementById('tipoManutencaoId').innerHTML = '<option value="">Selecione um patrimônio acima...</option>';

            const hintT = document.getElementById('tiposmanut-hint');
            if (hintT) { hintT.style.display = 'none'; hintT.textContent = ''; }

            const btnGerenciar = document.getElementById('btn-gerenciar-tipos');
            if (btnGerenciar) btnGerenciar.style.display = 'none';

            const hintP = document.getElementById('patrimonio-hint');
            if (hintP) { hintP.style.display = 'none'; hintP.textContent = ''; }

            document.getElementById('manutentorId').value = '';

            showModal('modal-criar-manutencao');
        }

        function filtrarPatrimonios() {
            const input = document.getElementById('patrimonio-busca');
            const lista = document.getElementById('patrimonio-opcoes');
            const q = (input.value || '').toLowerCase().trim();

            document.getElementById('patrimonioId').value = '';
            document.getElementById('tipo-patrimonio').value = '';
            resetTiposManutencao();

            if (!q) { lista.style.display = 'none'; return; }

            const filtrados = patrimonios
                .filter(p => (p.numero || '').toLowerCase().includes(q) || (p.descricao || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                lista.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum patrimônio encontrado.</div>`;
                lista.style.display = 'block';
                return;
            }

            lista.innerHTML = filtrados.map(p => `
                <div class="app-combobox-item" onclick="selecionarPatrimonio(${p.id})">
                    <div><b>${escapeHtml(p.numero || '')}</b> - ${escapeHtml(p.descricao || '')}</div>
                    <small class="app-muted">Status: ${escapeHtml(p.status || '-')} • Tipo: ${escapeHtml(p.tipo || '-')}</small>
                </div>
            `).join('');

            lista.style.display = 'block';
        }

        function selecionarPatrimonio(id) {
            const p = patrimonios.find(x => x.id === id);
            if (!p) return;

            document.getElementById('patrimonioId').value = p.id;
            document.getElementById('patrimonio-busca').value = `${p.numero} - ${p.descricao}`.trim();
            document.getElementById('tipo-patrimonio').value = p.tipo || '';

            const hint = document.getElementById('patrimonio-hint');
            if (p.status && p.status.toLowerCase().includes('manutenção')) {
                hint.textContent = `Atenção: este patrimônio já está com status "${p.status}". Se estiver em manutenção, o sistema vai bloquear nova abertura.`;
                hint.style.display = 'block';
            } else {
                hint.style.display = 'none';
            }

            document.getElementById('patrimonio-opcoes').style.display = 'none';
            carregarTiposManutencao(p.tipo);
        }

        function resetTiposManutencao() {
            const sel = document.getElementById('tipoManutencaoId');
            sel.innerHTML = '<option value="">Selecione um patrimônio acima...</option>';

            const hint = document.getElementById('tiposmanut-hint');
            hint.style.display = 'none';
            hint.textContent = '';

            const btnGerenciar = document.getElementById('btn-gerenciar-tipos');
            if (btnGerenciar) btnGerenciar.style.display = 'none';
        }

        function carregarTiposManutencao(tipoPatrimonio, selecionarNome) {
            const sel = document.getElementById('tipoManutencaoId');
            const hint = document.getElementById('tiposmanut-hint');
            const btnGerenciar = document.getElementById('btn-gerenciar-tipos');

            sel.innerHTML = '<option value="">Carregando...</option>';
            hint.style.display = 'none';
            hint.textContent = '';

            if (btnGerenciar) btnGerenciar.style.display = 'none';

            if (!tipoPatrimonio) {
                sel.innerHTML = '<option value="">Tipo de patrimônio não definido.</option>';
                return;
            }

            fetch(`/TiposManutencao/ListarPorTipo?nomeTipoPatrimonio=${encodeURIComponent(tipoPatrimonio)}`)
                .then(r => r.ok ? r.json() : [])
                .then(lista => {
                    if (!lista || !lista.length) {
                        sel.innerHTML = '<option value="">Nenhum tipo cadastrado</option>';

                        if (isAdmin && btnGerenciar) {
                            btnGerenciar.style.display = 'inline-flex';
                        } else {
                            hint.textContent = 'Não há tipos de manutenção cadastrados para este tipo. Solicite a um administrador.';
                            hint.style.display = 'block';
                        }
                        return;
                    }

                    sel.innerHTML = '<option value="">Selecione...</option>' +
                        lista.map(x => `<option value="${x.id}">${escapeHtml(x.nome)}</option>`).join('');

                    if (isAdmin && btnGerenciar) {
                        btnGerenciar.style.display = 'inline-flex';
                    }

                    if (selecionarNome) {
                        const alvo = (selecionarNome || '').trim().toLowerCase();
                        const opt = Array.from(sel.options).find(o => (o.textContent || '').trim().toLowerCase() === alvo);
                        if (opt) sel.value = opt.value;
                    }
                })
                .catch(() => {
                    sel.innerHTML = '<option value="">Erro ao carregar tipos</option>';
                    hint.textContent = 'Erro ao carregar tipos de manutenção.';
                    hint.style.display = 'block';

                    if (isAdmin && btnGerenciar) {
                        btnGerenciar.style.display = 'inline-flex';
                    }
                });
        }

        function filtrarManutentores() {
            const input = document.getElementById('manutentor-busca');
            const lista = document.getElementById('manutentor-opcoes');
            const q = (input.value || '').toLowerCase().trim();

            document.getElementById('manutentorId').value = '';

            if (!q) { lista.style.display = 'none'; return; }

            const filtrados = manutentores
                .filter(m => (m.nome || '').toLowerCase().includes(q))
                .slice(0, 25);

            if (!filtrados.length) {
                lista.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum manutentor encontrado.</div>`;
                lista.style.display = 'block';
                return;
            }

            lista.innerHTML = filtrados.map(m => `
                <div class="app-combobox-item" onclick="selecionarManutentor(${m.id})">
                    ${escapeHtml(m.nome || '')}
                </div>
            `).join('');

            lista.style.display = 'block';
        }

        function selecionarManutentor(id) {
            const m = manutentores.find(x => x.id === id);
            if (!m) return;

            document.getElementById('manutentorId').value = m.id;
            document.getElementById('manutentor-busca').value = m.nome || '';
            document.getElementById('manutentor-opcoes').style.display = 'none';
        }

        function formatarDataHoraBr(iso) {
            if (!iso) return "";
            const d = new Date(iso);
            if (isNaN(d.getTime())) return "";
            return d.toLocaleString("pt-BR");
        }

        function formatarMoeda(valor) {
            if (valor === null || valor === undefined || valor === "") return "";
            const n = Number(valor);
            if (isNaN(n)) return valor;
            return n.toLocaleString("pt-BR", { style: "currency", currency: "BRL" });
        }

        function codigoUsrPorId(id) {
            if (!id || id <= 0) return "";
            return "USR" + String(id).padStart(3, "0");
        }

        function abrirVerManutencao(btn) {
            const json = btn.getAttribute('data-manutencao') || '{}';
            let m = {};
            try { m = JSON.parse(json); } catch { }

            manutencaoAtual = m;

            const setVal = (id, val) => {
                const el = document.getElementById(id);
                if (!el) return;
                el.value = val ?? "";
            };

            setVal('m-codigo', m.codigo || "");
            setVal('m-status', m.status || "");
            setVal('m-patrimonio', `${m.patrimonioNumero || ""} - ${m.patrimonioDescricao || ""}`.trim());
            setVal('m-tipopatrimonio', m.tipoPatrimonio || "-");
            setVal('m-tipomanut', m.tipoManutencaoNome || "-");
            setVal('m-manutentor', m.manutentorNome || "-");
            setVal('m-abertaem', formatarDataHoraBr(m.abertaEm));

            const cod = (m.abertaPorCodigo || "").trim() || codigoUsrPorId(m.abertaPorId);
            const nome = `${m.abertaPorNome || ""} ${m.abertaPorSobrenome || ""}`.trim();
            setVal('m-abertapor', `${cod}${nome ? " • " + nome : ""}`.trim() || "-");

            setVal('m-custoestimado', formatarMoeda(m.custoEstimado));
            setVal('m-finalizadaem', formatarDataHoraBr(m.finalizadaEm));
            setVal('m-custofinal', formatarMoeda(m.custoFinal));
            setVal('m-statusfinal', m.statusFinalPatrimonio || "");
            setVal('m-observacoesfinais', m.observacoesFinais || "");

            const encerrada = (m.status === "Finalizada" || m.status === "Cancelada");
            const btnFinalizar = document.getElementById('btn-abrir-finalizar');
            const btnCancelar = document.getElementById('btn-abrir-cancelar');

            if (btnFinalizar) btnFinalizar.style.display = encerrada ? 'none' : 'inline-flex';
            if (btnCancelar) btnCancelar.style.display = encerrada ? 'none' : 'inline-flex';

            showModal('modal-ver-manutencao');
        }

        function abrirConfirmarCancelar() {
            if (!manutencaoAtual) return;
            document.getElementById('c-codigo').textContent = manutencaoAtual.codigo || "";
            document.getElementById('cancelar-id').value = manutencaoAtual.id || 0;
            showModal('modal-confirmar-cancelar');
        }

        function abrirModalFinalizar() {
            if (!manutencaoAtual) return;

            document.getElementById('finalizar-id').value = manutencaoAtual.id || 0;
            document.getElementById('f-codigo').value = manutencaoAtual.codigo || "";
            document.getElementById('f-patrimonio').value = `${manutencaoAtual.patrimonioNumero || ""} - ${manutencaoAtual.patrimonioDescricao || ""}`.trim();
            document.getElementById('f-tipopatrimonio').value = manutencaoAtual.tipoPatrimonio || "-";
            document.getElementById('f-tipomanut').value = manutencaoAtual.tipoManutencaoNome || "-";
            document.getElementById('f-manutentor').value = manutencaoAtual.manutentorNome || "-";
            document.getElementById('f-abertaem').value = formatarDataHoraBr(manutencaoAtual.abertaEm);

            const cod = (manutencaoAtual.abertaPorCodigo || "").trim() || codigoUsrPorId(manutencaoAtual.abertaPorId);
            const nome = `${manutencaoAtual.abertaPorNome || ""} ${manutencaoAtual.abertaPorSobrenome || ""}`.trim();
            document.getElementById('f-abertapor').value = `${cod}${nome ? " • " + nome : ""}`.trim() || "-";

            document.getElementById('f-custoestimado').value = formatarMoeda(manutencaoAtual.custoEstimado);

            showModal('modal-finalizar');
        }

        let tmTipoAtual = "";

        function abrirModalTiposManutencao() {
            const tipo = document.getElementById('tipo-patrimonio').value || "";
            if (!tipo) return;

            tmTipoAtual = tipo;
            document.getElementById('tm-tipo').textContent = tmTipoAtual;
            document.getElementById('tm-novo-nome').value = "";
            document.getElementById('tm-lista').innerHTML = `<li class="list-group-item app-muted">Carregando...</li>`;

            showModal('modal-tiposmanut');
            tmCarregar();
        }

        function tmCarregar() {
            fetch(`/TiposManutencao/ListarPorTipo?nomeTipoPatrimonio=${encodeURIComponent(tmTipoAtual)}`)
                .then(r => r.ok ? r.json() : [])
                .then(lista => {
                    const ul = document.getElementById('tm-lista');
                    if (!lista || !lista.length) {
                        ul.innerHTML = `<li class="list-group-item app-muted">Nenhum tipo cadastrado para este tipo de patrimônio.</li>`;
                        return;
                    }

                    ul.innerHTML = lista.map(x => `
                        <li class="list-group-item d-flex justify-content-between align-items-center" data-id="${x.id}">
                            <span class="tm-nome text-white">${escapeHtml(x.nome)}</span>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="tmAbrirEditar(${x.id})">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </li>
                    `).join('');
                })
                .catch(() => {
                    document.getElementById('tm-lista').innerHTML = `<li class="list-group-item text-danger">Erro ao carregar.</li>`;
                });
        }

        function tmAbrirEditar(id) {
            const li = document.querySelector(`#tm-lista li[data-id="${id}"]`);
            const atual = li ? (li.querySelector('.tm-nome')?.textContent || "") : "";

            document.getElementById('tm-edit-id').value = id;
            document.getElementById('tm-edit-nome').value = (atual || "").trim();

            const erro = document.getElementById('tm-edit-erro');
            if (erro) { erro.style.display = 'none'; erro.textContent = ''; }

            hideModal('modal-tiposmanut');
            setTimeout(() => {
                showModal('modal-tm-editar');
                setTimeout(() => document.getElementById('tm-edit-nome')?.focus(), 150);
            }, 200);
        }

        function tmCancelarEdicao() {
            hideModal('modal-tm-editar');
            setTimeout(() => showModal('modal-tiposmanut'), 200);
        }

        function tmSalvarEdicao() {
            const id = Number(document.getElementById('tm-edit-id').value || 0);
            const nome = (document.getElementById('tm-edit-nome').value || '').trim();

            const erro = document.getElementById('tm-edit-erro');
            const showErr = (msg) => {
                if (!erro) return;
                erro.textContent = msg;
                erro.style.display = 'block';
            };

            if (!id) return showErr('Registro inválido.');
            if (!nome) return showErr('Informe um nome.');

            const token = getAntiForgeryToken();
            const body = new URLSearchParams();
            body.append("__RequestVerificationToken", token);
            body.append("id", id);
            body.append("nome", nome);

            fetch('/TiposManutencao/Edit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            })
                .then(r => {
                    if (!r.ok) throw new Error();
                    hideModal('modal-tm-editar');
                    setTimeout(() => {
                        showModal('modal-tiposmanut');
                        tmCarregar();
                        carregarTiposManutencao(tmTipoAtual, nome);
                    }, 200);
                })
                .catch(() => showErr('Erro ao editar tipo de manutenção.'));
        }

        function tmCriar() {
            const nome = (document.getElementById('tm-novo-nome').value || '').trim();
            if (!nome) return;

            const token = getAntiForgeryToken();
            const body = new URLSearchParams();
            body.append("__RequestVerificationToken", token);
            body.append("nomeTipoPatrimonio", tmTipoAtual);
            body.append("nome", nome);

            fetch('/TiposManutencao/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            })
                .then(r => {
                    if (!r.ok) throw new Error();
                    document.getElementById('tm-novo-nome').value = "";
                    tmCarregar();
                    carregarTiposManutencao(tmTipoAtual, nome);
                })
                .catch(() => alert('Erro ao criar tipo de manutenção.'));
        }

        function escapeHtml(str) {
            return String(str)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        (function () {
            const form = document.getElementById('form-criar-manutencao');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                const patrimonioId = (document.getElementById('patrimonioId').value || '').trim();
                const tipoManutId = (document.getElementById('tipoManutencaoId').value || '').trim();
                let ok = true;

                const hintP = document.getElementById('patrimonio-hint');
                if (!patrimonioId) {
                    if (hintP) {
                        hintP.textContent = 'Selecione um patrimônio na lista.';
                        hintP.style.display = 'block';
                    }
                    ok = false;
                } else {
                    if (hintP && hintP.textContent.startsWith('Selecione um patrimônio')) hintP.style.display = 'none';
                }

                const hintT = document.getElementById('tiposmanut-hint');
                if (!tipoManutId) {
                    if (hintT) {
                        hintT.textContent = 'Selecione um tipo de manutenção.';
                        hintT.style.display = 'block';
                    }
                    ok = false;
                }

                if (!ok) e.preventDefault();
            });
        })();
    </script>
}
