@model IEnumerable<PatriControl.Web.Models.Manutencao>
@using PatriControl.Web.Models
@using System.Text.Json
@using System.Security.Claims

@{
    ViewData["Title"] = "Manutenções";

    var patrimonios = ViewBag.Patrimonios as List<Patrimonio> ?? new List<Patrimonio>();
    var manutentores = ViewBag.Manutentores as List<Manutentor> ?? new List<Manutentor>();

    // Model já vem paginado pelo Controller
    var emAndamento = Model.Where(m => m.Status != "Finalizada" && m.Status != "Cancelada").ToList();
    var finalizadas = Model.Where(m => m.Status == "Finalizada").ToList();
    var canceladas = Model.Where(m => m.Status == "Cancelada").ToList();

    // Totais reais (do filtro completo), para não depender do Model paginado
    var emAndamentoTotal = ViewBag.EmAndamentoTotal is int eat ? eat : emAndamento.Count;
    var finalizadasTotal = ViewBag.FinalizadasTotal is int ft ? ft : finalizadas.Count;
    var canceladasTotal = ViewBag.CanceladasTotal is int ct ? ct : canceladas.Count;

    // Preview de código (apenas visual; o controller gera o definitivo)
    var lastId = ViewBag.LastManutencaoId != null ? Convert.ToInt64(ViewBag.LastManutencaoId) : 0L;
    var codigoPreview = $"#MAN{(lastId + 1):0000}";

    var nomeUsuario = User?.Identity?.Name ?? "Usuário";
    var codigoUsuario = User?.Claims?.FirstOrDefault(c => c.Type == "Codigo")?.Value ?? "";

    var admin = User?.Claims?.FirstOrDefault(c => c.Type == "Administrador")?.Value == "True";

    // Dataset para JS
    var patrimoniosJs = JsonSerializer.Serialize(
        patrimonios.Select(p => new
        {
            id = p.Id,
            numero = p.Numero,
            descricao = p.Descricao,
            status = p.Status,
            tipo = p.Tipo
        })
    );

    var manutentoresJs = JsonSerializer.Serialize(
        manutentores.Select(m => new
        {
            id = m.Id,
            nome = m.Nome
        })
    );

    string BadgeStatusClass(string? status)
    {
        var s = (status ?? "").Trim().ToLowerInvariant();
        return s switch
        {
            "finalizada" => "app-badge-state app-badge-state-ok",
            "cancelada" => "app-badge-state app-badge-state-off",
            _ => "app-badge-state app-badge-state-warn"
        };
    }
}

<!-- Header -->
<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h4 class="mb-1 text-white">Manutenções</h4>
        <div class="app-muted">Abertura e histórico de manutenções.</div>
    </div>

    <div class="d-flex gap-2">
        <button type="button"
                onclick="abrirCriarManutencao()"
                class="app-icon-btn"
                aria-label="Abrir manutenção"
                title="Abrir manutenção">
            <i class="bi bi-plus-square-fill" style="font-size:34px;"></i>
        </button>
    </div>
</div>

@{
    var patrimoniosFiltro = ViewBag.Patrimonios as List<Patrimonio> ?? new List<Patrimonio>();
    var usuariosFiltro = ViewBag.Usuarios as List<Usuario> ?? new List<Usuario>();

    var patrimonioTexto = ViewBag.PatrimonioTexto as string ?? "";
    var usuarioTexto = ViewBag.UsuarioTexto as string ?? "";
    var patrimonioIdSel = ViewBag.PatrimonioId as int?;
    var usuarioIdSel = ViewBag.UsuarioId as int?;

    var patrimoniosFiltroJs = JsonSerializer.Serialize(
        patrimoniosFiltro.Select(p => new { id = p.Id, numero = p.Numero, descricao = p.Descricao })
    );

    var usuariosFiltroJs = JsonSerializer.Serialize(
        usuariosFiltro.Select(u => new { id = u.Id, codigo = u.Codigo, nome = u.Nome, sobrenome = u.Sobrenome, email = u.Email })
    );
}

<div class="app-card p-3 mb-3">
    <div class="mb-2">
        <div class="text-white fw-semibold">Filtros</div>
        <div class="app-muted small">Busque e selecione um patrimônio e/ou um usuário.</div>
    </div>

    <form method="get" asp-action="Index" class="row g-2 align-items-end">
        <input type="hidden" name="patrimonioId" id="filtro-patrimonio-id" value="@(patrimonioIdSel ?? 0)" />
        <input type="hidden" name="usuarioId" id="filtro-usuario-id" value="@(usuarioIdSel ?? 0)" />

        <div class="col-12 col-lg-5">
            <label class="app-label mb-1">Patrimônio</label>
            <div class="app-combobox">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text"
                           class="form-control"
                           name="patrimonio"
                           id="filtro-patrimonio-texto"
                           placeholder="Ex: 4569 ou Notebook Dell..."
                           value="@patrimonioTexto"
                           autocomplete="off"
                           oninput="filtrarPatrimoniosFiltro()" />
                </div>

                <div id="filtro-patrimonio-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <label class="app-label mb-1">Usuário (quem abriu)</label>
            <div class="app-combobox">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input type="text"
                           class="form-control"
                           name="usuario"
                           id="filtro-usuario-texto"
                           placeholder="Ex: USR002"
                           value="@usuarioTexto"
                           autocomplete="off"
                           oninput="filtrarUsuariosFiltro()" />
                </div>

                <div id="filtro-usuario-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-lg-auto">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" style="min-width:110px;">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary" style="min-width:110px;">Limpar</a>
            </div>
        </div>
    </form>
</div>

<!-- Board -->
<div class="row g-3">
    <!-- Em andamento -->
    <div class="col-12 col-lg-4">
        <div class="app-card p-3 h-100 app-board-col">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-white fw-semibold">Em andamento</div>
                <span class="badge badge-soft rounded-pill px-3 py-2">@emAndamentoTotal</span>
            </div>

            @if (!emAndamento.Any())
            {
                <div class="app-muted app-board-empty">Nenhuma manutenção em andamento nesta página.</div>
            }
            else
            {
                foreach (var m in emAndamento)
                {
                    var payload = JsonSerializer.Serialize(new
                    {
                        id = m.Id,
                        codigo = m.Codigo,
                        status = m.Status,
                        abertaEm = m.AbertaEm,
                        finalizadaEm = m.FinalizadaEm,
                        custoEstimado = m.CustoEstimado,
                        custoFinal = m.CustoFinal,
                        statusFinalPatrimonio = m.StatusFinalPatrimonio,
                        observacoesFinais = m.ObservacoesFinais,

                        abertaPorId = m.AbertaPorId,
                        abertaPorCodigo = m.AbertaPor != null ? m.AbertaPor.Codigo : null,
                        abertaPorNome = m.AbertaPor != null ? m.AbertaPor.Nome : null,
                        abertaPorSobrenome = m.AbertaPor != null ? m.AbertaPor.Sobrenome : null,

                        patrimonioId = m.PatrimonioId,
                        patrimonioNumero = m.Patrimonio?.Numero,
                        patrimonioDescricao = m.Patrimonio?.Descricao,
                        tipoPatrimonio = m.Patrimonio?.Tipo,

                        manutentorId = m.ManutentorId,
                        manutentorNome = m.Manutentor?.Nome,

                        tipoManutencaoId = m.TipoManutencaoId,
                        tipoManutencaoNome = m.TipoManutencao?.Nome
                    });

                    <div class="app-board-item">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <div class="text-white fw-bold">@m.Codigo</div>
                            <span class="badge rounded-pill px-3 py-2 @BadgeStatusClass(m.Status)">@m.Status</span>
                        </div>

                        <div class="text-white">
                            <b>@(m.Patrimonio?.Numero ?? "")</b> - @(m.Patrimonio?.Descricao ?? "")
                        </div>
                        <div class="app-muted small mt-1">Tipo: @(m.Patrimonio?.Tipo ?? "-")</div>
                        <div class="app-muted small">Manutenção: @(m.TipoManutencao?.Nome ?? "-")</div>
                        <div class="app-muted small">Manutentor: @(m.Manutentor?.Nome ?? "-")</div>
                        <div class="app-muted small">Aberta em: @m.AbertaEm.ToString("dd/MM/yyyy HH:mm")</div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary"
                                    data-manutencao='@Html.Raw(payload)'
                                    onclick="abrirVerManutencao(this)">
                                Ver
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Finalizadas -->
    <div class="col-12 col-lg-4">
        <div class="app-card p-3 h-100 app-board-col">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-white fw-semibold">Finalizadas</div>
                <span class="badge badge-soft rounded-pill px-3 py-2">@finalizadasTotal</span>
            </div>

            @if (!finalizadas.Any())
            {
                <div class="app-muted app-board-empty">Nenhuma manutenção finalizada nesta página.</div>
            }
            else
            {
                foreach (var m in finalizadas)
                {
                    var payload = JsonSerializer.Serialize(new
                    {
                        id = m.Id,
                        codigo = m.Codigo,
                        status = m.Status,
                        abertaEm = m.AbertaEm,
                        finalizadaEm = m.FinalizadaEm,
                        custoEstimado = m.CustoEstimado,
                        custoFinal = m.CustoFinal,
                        statusFinalPatrimonio = m.StatusFinalPatrimonio,
                        observacoesFinais = m.ObservacoesFinais,

                        abertaPorId = m.AbertaPorId,
                        abertaPorCodigo = m.AbertaPor != null ? m.AbertaPor.Codigo : null,
                        abertaPorNome = m.AbertaPor != null ? m.AbertaPor.Nome : null,
                        abertaPorSobrenome = m.AbertaPor != null ? m.AbertaPor.Sobrenome : null,

                        patrimonioId = m.PatrimonioId,
                        patrimonioNumero = m.Patrimonio?.Numero,
                        patrimonioDescricao = m.Patrimonio?.Descricao,
                        tipoPatrimonio = m.Patrimonio?.Tipo,

                        manutentorId = m.ManutentorId,
                        manutentorNome = m.Manutentor?.Nome,

                        tipoManutencaoId = m.TipoManutencaoId,
                        tipoManutencaoNome = m.TipoManutencao?.Nome
                    });

                    <div class="app-board-item">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <div class="text-white fw-bold">@m.Codigo</div>
                            <span class="badge rounded-pill px-3 py-2 @BadgeStatusClass("Finalizada")">Finalizada</span>
                        </div>

                        <div class="text-white">
                            <b>@(m.Patrimonio?.Numero ?? "")</b> - @(m.Patrimonio?.Descricao ?? "")
                        </div>
                        <div class="app-muted small mt-1">Tipo: @(m.Patrimonio?.Tipo ?? "-")</div>
                        <div class="app-muted small">Manutenção: @(m.TipoManutencao?.Nome ?? "-")</div>
                        <div class="app-muted small">Manutentor: @(m.Manutentor?.Nome ?? "-")</div>
                        <div class="app-muted small">Aberta em: @m.AbertaEm.ToString("dd/MM/yyyy HH:mm")</div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary"
                                    data-manutencao='@Html.Raw(payload)'
                                    onclick="abrirVerManutencao(this)">
                                Ver
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Canceladas -->
    <div class="col-12 col-lg-4">
        <div class="app-card p-3 h-100 app-board-col">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-white fw-semibold">Canceladas</div>
                <span class="badge badge-soft rounded-pill px-3 py-2">@canceladasTotal</span>
            </div>

            @if (!canceladas.Any())
            {
                <div class="app-muted app-board-empty">Nenhuma manutenção cancelada nesta página.</div>
            }
            else
            {
                foreach (var m in canceladas)
                {
                    var payload = JsonSerializer.Serialize(new
                    {
                        id = m.Id,
                        codigo = m.Codigo,
                        status = m.Status,
                        abertaEm = m.AbertaEm,
                        finalizadaEm = m.FinalizadaEm,
                        custoEstimado = m.CustoEstimado,
                        custoFinal = m.CustoFinal,
                        statusFinalPatrimonio = m.StatusFinalPatrimonio,
                        observacoesFinais = m.ObservacoesFinais,

                        abertaPorId = m.AbertaPorId,
                        abertaPorCodigo = m.AbertaPor != null ? m.AbertaPor.Codigo : null,
                        abertaPorNome = m.AbertaPor != null ? m.AbertaPor.Nome : null,
                        abertaPorSobrenome = m.AbertaPor != null ? m.AbertaPor.Sobrenome : null,

                        patrimonioId = m.PatrimonioId,
                        patrimonioNumero = m.Patrimonio?.Numero,
                        patrimonioDescricao = m.Patrimonio?.Descricao,
                        tipoPatrimonio = m.Patrimonio?.Tipo,

                        manutentorId = m.ManutentorId,
                        manutentorNome = m.Manutentor?.Nome,

                        tipoManutencaoId = m.TipoManutencaoId,
                        tipoManutencaoNome = m.TipoManutencao?.Nome
                    });

                    <div class="app-board-item">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <div class="text-white fw-bold">@m.Codigo</div>
                            <span class="badge rounded-pill px-3 py-2 @BadgeStatusClass("Cancelada")">Cancelada</span>
                        </div>

                        <div class="text-white">
                            <b>@(m.Patrimonio?.Numero ?? "")</b> - @(m.Patrimonio?.Descricao ?? "")
                        </div>
                        <div class="app-muted small mt-1">Tipo: @(m.Patrimonio?.Tipo ?? "-")</div>
                        <div class="app-muted small">Manutenção: @(m.TipoManutencao?.Nome ?? "-")</div>
                        <div class="app-muted small">Manutentor: @(m.Manutentor?.Nome ?? "-")</div>
                        <div class="app-muted small">Aberta em: @m.AbertaEm.ToString("dd/MM/yyyy HH:mm")</div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary"
                                    data-manutencao='@Html.Raw(payload)'
                                    onclick="abrirVerManutencao(this)">
                                Ver
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Paginação (padrão do sistema) -->
@if (ViewBag.Paginacao != null && (int)ViewBag.Paginacao.TotalPages > 1)
{
    <div class="mt-3">
        @await Html.PartialAsync("_paginacao", (object)ViewBag.Paginacao)
    </div>
}

<!-- =================================================
   MODAL: CRIAR MANUTENÇÃO (Bootstrap)
   ================================================= -->
<div class="modal fade" id="modal-criar-manutencao" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Abrir Manutenção</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Create" method="post" id="form-criar-manutencao">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Código da manutenção</label>
                            <input class="form-control" value="@codigoPreview" disabled />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Status</label>
                            <input class="form-control" value="Em andamento" disabled />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Aberta em</label>
                            <input class="form-control" id="create-abertaem" disabled />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Aberta por</label>
                            <input class="form-control" value="@($"{nomeUsuario}{(string.IsNullOrWhiteSpace(codigoUsuario) ? "" : $" • {codigoUsuario}")}")" disabled />
                        </div>

                        <div class="col-12">
                            <label class="form-label app-label app-label-required">Patrimônio (pesquise e selecione)</label>

                            <div class="app-combobox">
                                <input type="hidden" id="patrimonioId" name="patrimonioId" />

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-box-seam"></i>
                                    </span>

                                    <input type="text"
                                           id="patrimonio-busca"
                                           class="form-control"
                                           placeholder="Digite número ou descrição..."
                                           autocomplete="off"
                                           oninput="filtrarPatrimonios()" />
                                </div>

                                <div id="patrimonio-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>

                            <div class="app-muted small mt-2" id="patrimonio-hint" style="display:none;"></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo de Patrimônio</label>

                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-tags"></i>
                                </span>

                                <input class="form-control" id="tipo-patrimonio" disabled />
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Tipo de Manutenção <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2 align-items-center">
                                <select class="form-select" id="tipoManutencaoId" name="tipoManutencaoId" required>
                                    <option value="">Selecione um patrimônio acima...</option>
                                </select>

                                @if (admin)
                                {
                                    <button type="button"
                                            id="btn-gerenciar-tipos"
                                            class="btn btn-outline-secondary btn-sm"
                                            title="Gerenciar tipos de manutenção"
                                            style="display:none;"
                                            onclick="abrirModalTiposManutencao()">
                                        <i class="bi bi-list"></i>
                                    </button>
                                }
                            </div>
                            <div class="app-muted small mt-2" id="tiposmanut-hint" style="display:none;"></div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Manutentor</label>

                            <div class="app-combobox">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-person-badge"></i>
                                    </span>

                                    <input type="text"
                                           id="manutentor-busca"
                                           class="form-control"
                                           placeholder="Digite para buscar..."
                                           autocomplete="off"
                                           oninput="filtrarManutentores()" />
                                </div>

                                <input type="hidden" id="manutentorId" name="manutentorId" />
                                <div id="manutentor-opcoes" class="app-combobox-list" style="display:none;"></div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label app-label">Custo estimado</label>
                            <input class="form-control" name="custoEstimado" type="number" step="0.01" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary" type="submit">Salvar</button>
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL: VER MANUTENÇÃO (Bootstrap)
   ================================================= -->
<div class="modal fade" id="modal-ver-manutencao" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white">Detalhes da Manutenção</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Código</label>
                        <input class="form-control" id="m-codigo" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Status</label>
                        <input class="form-control" id="m-status" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Patrimônio</label>
                        <input class="form-control" id="m-patrimonio" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Tipo de Patrimônio</label>
                        <input class="form-control" id="m-tipopatrimonio" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Tipo de Manutenção</label>
                        <input class="form-control" id="m-tipomanut" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Manutentor</label>
                        <input class="form-control" id="m-manutentor" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Aberta em</label>
                        <input class="form-control" id="m-abertaem" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Aberta por</label>
                        <input class="form-control" id="m-abertapor" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Custo estimado</label>
                        <input class="form-control" id="m-custoestimado" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Finalizada em</label>
                        <input class="form-control" id="m-finalizadaem" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Custo final</label>
                        <input class="form-control" id="m-custofinal" readonly tabindex="-1" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label app-label">Status Final Patrimônio</label>
                        <input class="form-control" id="m-statusfinal" readonly tabindex="-1" />
                    </div>

                    <div class="col-12">
                        <label class="form-label app-label">Observações finais</label>
                        <textarea class="form-control" id="m-observacoesfinais" rows="3" readonly tabindex="-1"></textarea>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button id="btn-abrir-finalizar" type="button" class="btn app-btn-ok" onclick="abrirModalFinalizar()">Finalizar</button>
                <button id="btn-abrir-cancelar" type="button" class="btn btn-danger" onclick="abrirConfirmarCancelar()">Cancelar manutenção</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL: CONFIRMAR CANCELAMENTO (Bootstrap)
   ================================================= -->
<div class="modal fade" id="modal-confirmar-cancelar" tabindex="-1" aria-hidden="true">
