<!-- TABELAS -->
<div class="row g-3">
    <div class="col-12 col-xl-6">
        <div class="app-card p-3 h-100">
            <div class="text-white fw-semibold mb-1">Patrimônios recentes</div>
            <div class="app-muted small mb-2">Últimos registros criados (conforme filtros).</div>

            <div class="table-responsive">
                <table class="table table-dark-soft table-hover align-middle mb-0">
                    <thead>
                        <tr class="app-table-head">
                            <th style="width:160px;">NÚMERO</th>
                            <th>DESCRIÇÃO</th>
                            <th style="width:240px;">UNIDADE</th>
                            <th style="width:190px;">STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Recentes == null || !Model.Recentes.Any())
                        {
                            <tr><td colspan="4" class="app-muted">Nenhum patrimônio encontrado.</td></tr>
                        }
                        else
                        {
                            foreach (var p in Model.Recentes)
                            {
                                var num = string.IsNullOrWhiteSpace(p.Numero) ? "-" : p.Numero;
                                <tr>
                                    <td class="fw-semibold text-white">@num</td>
                                    <td class="text-white">@p.Descricao</td>
                                    <td class="app-muted">@p.Unidade</td>
                                    <td class="app-muted">@p.Status</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="app-card p-3 h-100">
            <div class="text-white fw-semibold mb-1">Manutenções recentes</div>
            <div class="app-muted small mb-2">Últimas aberturas registradas.</div>

            <div class="table-responsive">
                <table class="table table-dark-soft table-hover align-middle mb-0">
                    <thead>
                        <tr class="app-table-head">
                            <th style="width:140px;">CÓDIGO</th>
                            <th>PATRIMÔNIO</th>
                            <th style="width:140px;">STATUS</th>
                            <th style="width:160px;">ABERTA EM</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ManutencoesRecentes == null || !Model.ManutencoesRecentes.Any())
                        {
                            <tr><td colspan="4" class="app-muted">Nenhuma manutenção encontrada.</td></tr>
                        }
                        else
                        {
                            foreach (var m in Model.ManutencoesRecentes)
                            {
                                var pat = $"{m.PatrimonioNumero ?? ""} - {m.PatrimonioDescricao ?? ""}".Trim();
                                <tr>
                                    <td class="fw-semibold text-white">@m.Codigo</td>
                                    <td class="text-white">@pat</td>
                                    <td class="app-muted">@m.Status</td>
                                    <td class="app-muted">@m.AbertaEm.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js (CDN). Se preferir, você pode baixar e servir localmente -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    <script>
        const dsUnidades = @Html.Raw(unidadesJs);
        const dsTipos = @Html.Raw(tiposJs);
        const dsFornecedores = @Html.Raw(fornecedoresJs);

        const chartStatusData = @Html.Raw(statusChart);
        const chartUnidadesData = @Html.Raw(topUnidadesChart);
        const chartTiposData = @Html.Raw(topTiposChart);
        const chartManutMesData = @Html.Raw(manutMesChart);
        const chartCustoMesData = @Html.Raw(custoMesChart);

        function escapeHtml(str) {
            return String(str)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function hideIfClickOutside(inputId, listId) {
            document.addEventListener('click', function (e) {
                const input = document.getElementById(inputId);
                const box = document.getElementById(listId);
                if (!input || !box) return;
                if (!box.contains(e.target) && e.target !== input) box.style.display = 'none';
            });
        }

        function setupCombobox({ inputId, hiddenId, listId, dataset }) {
            hideIfClickOutside(inputId, listId);

            window[inputId + "_filter"] = function () {
                const input = document.getElementById(inputId);
                const hid = document.getElementById(hiddenId);
                const box = document.getElementById(listId);
                if (!input || !hid || !box) return;

                const q = (input.value || '').toLowerCase().trim();
                hid.value = ""; // reset até selecionar

                if (!q) { box.style.display = 'none'; return; }

                const itens = dataset
                    .filter(x => (x.nome || '').toLowerCase().includes(q))
                    .slice(0, 25);

                if (!itens.length) {
                    box.innerHTML = `<div class="app-combobox-item app-muted" style="cursor:default;">Nenhum encontrado.</div>`;
                    box.style.display = 'block';
                    return;
                }

                box.innerHTML = itens.map(x => `
                    <div class="app-combobox-item"
                         onclick="selectComboboxValue('${inputId}','${hiddenId}','${listId}','${escapeHtml(x.nome)}')">
                        ${escapeHtml(x.nome)}
                    </div>
                `).join('');

                box.style.display = 'block';
            };
        }

        function selectComboboxValue(inputId, hiddenId, listId, value) {
            const input = document.getElementById(inputId);
            const hid = document.getElementById(hiddenId);
            const box = document.getElementById(listId);

            if (input) input.value = value;
            if (hid) hid.value = value;
            if (box) box.style.display = 'none';
        }

        function filtrarUnidadesDash() { window["f-unidade-texto_filter"](); }
        function filtrarTiposDash() { window["f-tipo-texto_filter"](); }
        function filtrarFornecedoresDash() { window["f-fornecedor-texto_filter"](); }

        setupCombobox({ inputId: "f-unidade-texto", hiddenId: "f-unidade", listId: "f-unidade-opcoes", dataset: dsUnidades });
        setupCombobox({ inputId: "f-tipo-texto", hiddenId: "f-tipo", listId: "f-tipo-opcoes", dataset: dsTipos });
        setupCombobox({ inputId: "f-fornecedor-texto", hiddenId: "f-fornecedor", listId: "f-fornecedor-opcoes", dataset: dsFornecedores });

        function cssVar(name) {
            return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        }

        function ensureData(d) {
            return d && d.labels && d.values && d.labels.length;
        }

        function statusColor(label) {
            const k = (label || '').trim().toLowerCase();

            if (k === 'ativo') return cssVar('--pc-status-ativo') || cssVar('--app-success');
            if (k === 'aguardando manutenção' || k === 'aguardando manutencao') return cssVar('--pc-status-aguardando') || cssVar('--app-blue');
            if (k === 'baixado') return cssVar('--pc-status-baixado') || cssVar('--app-danger');
            if (k === 'em manutenção' || k === 'em manutencao') return cssVar('--pc-status-manutencao') || cssVar('--app-warning');
            if (k === 'emprestado') return cssVar('--pc-status-emprestado') || cssVar('--app-info');

            // fallback
            return cssVar('--app-primary') || '#999';
        } // ✅ <-- FECHAMENTO QUE ESTAVA FALTANDO

        function buildDoughnut(canvasId, d) {
            const el = document.getElementById(canvasId);
            if (!el || !ensureData(d) || typeof Chart === "undefined") return;

            new Chart(el, {
                type: 'doughnut',
                data: {
                    labels: d.labels,
                    datasets: [{
                        data: d.values,
                        backgroundColor: d.labels.map(l => statusColor(l))
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: '#E7EAF1' } }
                    }
                }
            });
        }

        function buildBar(canvasId, d) {
            const el = document.getElementById(canvasId);
            if (!el || !ensureData(d) || typeof Chart === "undefined") return;

            const one = (d.labels?.length || 0) === 1;

            new Chart(el, {
                type: 'bar',
                data: {
                    labels: d.labels,
                    datasets: [{
                        label: '',
                        data: d.values,

                        //  controla largura da barra
                        maxBarThickness: one ? 140 : 56,
                        categoryPercentage: one ? 0.22 : 0.72,
                        barPercentage: one ? 0.55 : 0.85,

                        backgroundColor: cssVar('--app-primary') || '#AF1763'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            offset: true, //  ajuda a não “colar” nas bordas quando tem pouco item
                            ticks: { color: '#E7EAF1' },
                            grid: { color: 'rgba(255,255,255,.06)' }
                        },
                        y: {
                            ticks: { color: '#E7EAF1' },
                            grid: { color: 'rgba(255,255,255,.06)' }
                        }
                    }
                }
            });
        }

        function buildLine(canvasId, d) {
            const el = document.getElementById(canvasId);
            if (!el || !ensureData(d) || typeof Chart === "undefined") return;

            new Chart(el, {
                type: 'line',
                data: {
                    labels: d.labels,
                    datasets: [{
                        label: 'Abertas',
                        data: d.values,
                        borderColor: cssVar('--app-primary') || '#AF1763',
                        backgroundColor: 'rgba(175,23,99,.15)',
                        fill: true,
                        tension: 0.25
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { labels: { color: '#E7EAF1' } } },
                    scales: {
                        x: { ticks: { color: '#E7EAF1' }, grid: { color: 'rgba(255,255,255,.06)' } },
                        y: { ticks: { color: '#E7EAF1' }, grid: { color: 'rgba(255,255,255,.06)' } }
                    }
                }
            });
        }

        function normalizeChartData(d) {
            if (!d) return { labels: [], values: [] };
            const labels = d.labels ?? d.Labels ?? [];
            const values = d.values ?? d.Values ?? [];
            return { labels, values };
        }

        window.addEventListener('load', () => {
            const s  = normalizeChartData(chartStatusData);
            const u  = normalizeChartData(chartUnidadesData);
            const t  = normalizeChartData(chartTiposData);
            const mm = normalizeChartData(chartManutMesData);
            const cm = normalizeChartData(chartCustoMesData);

            buildDoughnut('chartStatus', s);
            buildBar('chartUnidades', u);
            buildBar('chartTipos', t);
            buildLine('chartManutMes', mm);
            buildBar('chartCustoMes', cm);
        });
    </script>
}
