@model PatriControl.Web.Models.ViewModels.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";

    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    var unidades = (ViewBag.Unidades as IEnumerable<string>) ?? Enumerable.Empty<string>();
    var tipos = (ViewBag.Tipos as IEnumerable<string>) ?? Enumerable.Empty<string>();
    var fornecedores = (ViewBag.Fornecedores as IEnumerable<string>) ?? Enumerable.Empty<string>();

    var statusLista = (IEnumerable<string>)ViewBag.StatusLista;
    var condicaoLista = (IEnumerable<string>)ViewBag.CondicaoLista;

    var unidadesJs = JsonSerializer.Serialize(unidades.Select(x => new { nome = x }), jsonOpts);
    var tiposJs = JsonSerializer.Serialize(tipos.Select(x => new { nome = x }), jsonOpts);
    var fornecedoresJs = JsonSerializer.Serialize(fornecedores.Select(x => new { nome = x }), jsonOpts);

    var statusChart = JsonSerializer.Serialize(Model.StatusPatrimonios, jsonOpts);
    var topUnidadesChart = JsonSerializer.Serialize(Model.TopUnidades, jsonOpts);
    var topTiposChart = JsonSerializer.Serialize(Model.TopTipos, jsonOpts);
    var manutMesChart = JsonSerializer.Serialize(Model.ManutencoesPorMes, jsonOpts);
    var custoMesChart = JsonSerializer.Serialize(Model.CustoPorMes, jsonOpts);

    string money(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h4 class="mb-1 text-white">Dashboard</h4>
        <div class="app-muted">Análise de patrimônios e manutenções</div>
    </div>
</div>

<!-- FILTROS -->
<form method="get" class="app-card p-3 mb-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
        <div class="text-white fw-semibold">Filtros</div>
        <div class="app-muted small">
            Período: <b class="text-white">@Model.DataInicio.ToString("dd/MM/yyyy")</b> até <b class="text-white">@Model.DataFim.ToString("dd/MM/yyyy")</b>
        </div>
    </div>

    <div class="row g-2 g-md-3">
        <div class="col-12 col-md-3">
            <label class="form-label app-label">Data início</label>
            <input type="date" name="de" class="form-control" value="@Model.DataInicio.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label app-label">Data fim</label>
            <input type="date" name="ate" class="form-control" value="@Model.DataFim.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-12 col-md-6">
            <label class="form-label app-label">Unidade</label>
            <div class="app-combobox">
                <input type="hidden" id="f-unidade" name="unidade" value="@(Model.Unidade ?? "")" />
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-building"></i></span>
                    <input type="text"
                           id="f-unidade-texto"
                           class="form-control"
                           placeholder="Digite para buscar..."
                           autocomplete="off"
                           value="@(Model.Unidade ?? "")"
                           oninput="filtrarUnidadesDash()" />
                </div>
                <div id="f-unidade-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label app-label">Tipo</label>
            <div class="app-combobox">
                <input type="hidden" id="f-tipo" name="tipo" value="@(Model.Tipo ?? "")" />
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-grid"></i></span>
                    <input type="text"
                           id="f-tipo-texto"
                           class="form-control"
                           placeholder="Digite para buscar..."
                           autocomplete="off"
                           value="@(Model.Tipo ?? "")"
                           oninput="filtrarTiposDash()" />
                </div>
                <div id="f-tipo-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label app-label">Fornecedor</label>
            <div class="app-combobox">
                <input type="hidden" id="f-fornecedor" name="fornecedor" value="@(Model.Fornecedor ?? "")" />
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-truck"></i></span>
                    <input type="text"
                           id="f-fornecedor-texto"
                           class="form-control"
                           placeholder="Digite para buscar..."
                           autocomplete="off"
                           value="@(Model.Fornecedor ?? "")"
                           oninput="filtrarFornecedoresDash()" />
                </div>
                <div id="f-fornecedor-opcoes" class="app-combobox-list" style="display:none;"></div>
            </div>
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label app-label">Status</label>
            <select class="form-select" name="status">
                @foreach (var s in statusLista)
                {
                    <option value="@s" selected="@(s == (Model.Status ?? "") ? "selected" : null)">
                        @(string.IsNullOrWhiteSpace(s) ? "(Todos)" : s)
                    </option>
                }
            </select>
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label app-label">Condição</label>
            <select class="form-select" name="condicao">
                @foreach (var c in condicaoLista)
                {
                    <option value="@c" selected="@(c == (Model.Condicao ?? "") ? "selected" : null)">
                        @(string.IsNullOrWhiteSpace(c) ? "(Todas)" : c)
                    </option>
                }
            </select>
        </div>

        <div class="col-12 col-md-4 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary w-100">Aplicar</button>
            <a class="btn btn-outline-secondary w-100" href="@Url.Action("Index", "Dashboard")">Limpar</a>
        </div>
    </div>
</form>

