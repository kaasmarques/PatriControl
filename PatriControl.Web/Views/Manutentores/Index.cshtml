@using System.Text.Json
@model IEnumerable<PatriControl.Web.Models.Manutentor>

@{
    ViewData["Title"] = "Manutentores";

    string filtro = ViewBag.Filtro as string ?? "";
    int pageSize = ViewBag.PageSize != null ? Convert.ToInt32(ViewBag.PageSize) : 10;

    int total = ViewBag.Total != null ? Convert.ToInt32(ViewBag.Total) : (Model?.Count() ?? 0);
    int paginaAtual = ViewBag.Page != null ? Convert.ToInt32(ViewBag.Page) : 1;
    int totalPages = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
    int exibindo = ViewBag.Exibindo != null ? Convert.ToInt32(ViewBag.Exibindo) : (Model?.Count() ?? 0);
}

<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h4 class="mb-1 text-white">Manutentores</h4>
        <div class="app-muted">Gerencie manutentores cadastrados no sistema.</div>
    </div>

    <!-- Botão igual ao de Patrimônio -->
    <button type="button"
            class="app-icon-btn"
            aria-label="Adicionar manutentor"
            title="Adicionar manutentor"
            data-bs-toggle="modal"
            data-bs-target="#modalNovoManutentor">
        <i class="bi bi-plus-square-fill" style="font-size:34px;"></i>
    </button>
</div>

<div class="app-card p-3">

    <!-- Cabeçalho do bloco (igual ao padrão Unidades/Patrimônios) -->
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="text-white fw-semibold">Filtros</div>

        <div class="app-muted small text-end">
            Total: <b class="text-white">@total</b>
            <span class="mx-1">•</span>
            Página <b class="text-white">@paginaAtual</b>/<b class="text-white">@totalPages</b>
            <span class="mx-1">•</span>
            Exibindo <b class="text-white">@exibindo</b>
        </div>
    </div>

    <!--  FILTRO SERVER SIDE (botões AO LADO do input) -->
    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-3">
        <!-- Quando filtrar, sempre volta pra página 1 -->
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@pageSize" />

        <div class="col-12 col-md-7">
            <label class="app-label mb-1">Buscar</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text"
                       name="filtro"
                       value="@filtro"
                       class="form-control"
                       placeholder="Filtrar manutentores..." />
            </div>
        </div>

        <div class="col-12 col-md-auto">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" style="min-width:110px;">
                    Filtrar
                </button>

                <a asp-action="Index"
                   asp-route-page="1"
                   asp-route-pageSize="@pageSize"
                   class="btn btn-outline-secondary"
                   style="min-width:110px;">
                    Limpar
                </a>
            </div>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-dark-soft table-hover align-middle mb-0">
            <thead>
                <tr class="app-table-head">
                    <th>MANUTENTOR</th>
                    <th style="width:160px;" class="text-end">AÇÕES</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="2" class="app-muted">Nenhum manutentor cadastrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var m in Model)
                    {
                        <tr>
                            <td class="text-white">@m.Nome</td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        data-id="@m.Id"
                                        data-nome="@m.Nome"
                                        onclick="abrirModalEditarManutentor(this)">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <!-- PAGINAÇÃO -->
    @if (ViewBag.Paginacao != null && totalPages > 1)
    {
        <div class="mt-3">
            @await Html.PartialAsync("_paginacao", (object)ViewBag.Paginacao)
        </div>
    }
</div>

<!-- =================================================
   MODAL (BOOTSTRAP): NOVO MANUTENTOR
   ================================================= -->
<div class="modal fade" id="modalNovoManutentor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-white">Novo Manutentor</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Create" method="post" id="formNovoManutentor">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <label class="form-label app-muted app-label-required">Nome</label>
                    <input class="form-control" name="nome" required />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- =================================================
   MODAL (BOOTSTRAP): EDITAR MANUTENTOR
   ================================================= -->
<div class="modal fade" id="modalEditarManutentor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title text-white">Editar Manutentor</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <form asp-action="Edit" method="post" id="formEditarManutentor">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="edit-id" />

                <div class="modal-body">
                    <label class="form-label app-muted app-label-required">Nome</label>
                    <input class="form-control" name="nome" id="edit-nome" required />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModalEditarManutentor(btn) {
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome') || '';

            document.getElementById('edit-id').value = id;
            document.getElementById('edit-nome').value = nome;

            const modalEl = document.getElementById('modalEditarManutentor');
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        }

        // limpa o form do "novo" sempre que abrir
        document.addEventListener('DOMContentLoaded', function () {
            const modalNovoEl = document.getElementById('modalNovoManutentor');
            if (modalNovoEl) {
                modalNovoEl.addEventListener('show.bs.modal', function () {
                    const form = document.getElementById('formNovoManutentor');
                    if (form) form.reset();
                });
            }
        });
    </script>
}
